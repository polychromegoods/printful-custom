{% comment %}
  Product Customizer Block (Dynamic)
  
  Fetches the product template configuration from the app API and
  dynamically renders the appropriate customization controls:
  - Text layers: input + font picker + color picker
  - Image layers: file upload zone
  - Fixed image layers: displayed but not editable
  
  The live preview overlays all layers on the product mockup image,
  positioned according to the template's print area settings.
  
  Variant-aware: swaps mockup image when customer changes color variant.
{% endcomment %}

<style>
  .pc-customizer {
    margin: 16px 0;
    padding: 20px;
    border: 1px solid #e5e5e5;
    border-radius: 8px;
    background: #fafafa;
    font-family: 'Avenir Next', -apple-system, BlinkMacSystemFont, sans-serif;
  }
  .pc-customizer__title {
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 16px;
    color: #1a1a1a;
  }
  .pc-customizer__loading {
    text-align: center;
    padding: 20px;
    color: #999;
    font-size: 14px;
  }
  .pc-customizer__not-configured {
    display: none;
  }
  .pc-customizer__field {
    margin-bottom: 16px;
  }
  .pc-customizer__label {
    display: block;
    font-size: 13px;
    font-weight: 500;
    margin-bottom: 6px;
    color: #333;
  }
  .pc-customizer__input {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid #ccc;
    border-radius: 6px;
    font-size: 18px;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 4px;
    box-sizing: border-box;
    font-family: inherit;
  }
  .pc-customizer__input:focus {
    outline: none;
    border-color: #333;
  }
  .pc-customizer__char-count {
    font-size: 11px;
    color: #999;
    text-align: right;
    margin-top: 4px;
  }
  .pc-customizer__fonts {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .pc-customizer__font-btn {
    flex: 1;
    min-width: 80px;
    padding: 10px;
    border: 2px solid #ddd;
    border-radius: 6px;
    background: white;
    cursor: pointer;
    text-align: center;
    transition: all 0.2s;
  }
  .pc-customizer__font-btn:hover {
    border-color: #999;
  }
  .pc-customizer__font-btn.active {
    border-color: #333;
    background: #f5f5f5;
  }
  .pc-customizer__font-preview {
    font-size: 20px;
    line-height: 1.2;
    display: block;
  }
  .pc-customizer__font-name {
    display: block;
    font-size: 11px;
    font-weight: 500;
    margin-top: 4px;
    font-family: 'Avenir Next', sans-serif;
  }
  .pc-customizer__colors {
    display: flex !important;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
    padding: 4px 0;
  }
  .pc-customizer__color-swatch {
    width: 28px !important;
    height: 28px !important;
    min-width: 28px !important;
    min-height: 28px !important;
    border-radius: 50% !important;
    border: 2px solid #ccc !important;
    cursor: pointer;
    transition: all 0.2s;
    box-shadow: 0 0 0 1px rgba(0,0,0,0.08);
    display: inline-block !important;
    padding: 0 !important;
    margin: 0;
    vertical-align: middle;
    box-sizing: border-box;
  }
  .pc-customizer__color-swatch:hover {
    transform: scale(1.15);
    border-color: #999;
  }
  .pc-customizer__color-swatch.active {
    border-color: #333;
    box-shadow: 0 0 0 2px white, 0 0 0 4px #333;
  }
  .pc-customizer__color-name {
    font-size: 11px;
    color: #666;
    margin-top: 6px;
  }
  .pc-customizer__upload-zone {
    border: 2px dashed #ccc;
    border-radius: 8px;
    padding: 20px;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s;
    background: white;
  }
  .pc-customizer__upload-zone:hover {
    border-color: #999;
    background: #f9f9f9;
  }
  .pc-customizer__upload-zone.has-file {
    border-color: #333;
    border-style: solid;
  }
  .pc-customizer__upload-text {
    font-size: 13px;
    color: #666;
  }
  .pc-customizer__upload-preview {
    max-width: 120px;
    max-height: 120px;
    margin: 8px auto;
    display: none;
  }
  .pc-customizer__upload-preview.visible {
    display: block;
  }
  .pc-customizer__upload-input {
    display: none;
  }
  .monogram-overlay-canvas {
    position: absolute;
    pointer-events: none;
    z-index: 10;
  }
</style>

<div class="pc-customizer" id="pc-customizer">
  <div class="pc-customizer__title">{{ block.settings.title }}</div>
  <div class="pc-customizer__loading" id="pc-loading">Loading customization options...</div>
  <div class="pc-customizer__not-configured" id="pc-not-configured">
    <p style="color:#999; font-size:13px;">Personalization is not yet configured for this product.</p>
  </div>
  <div id="pc-layers-container" style="display:none;"></div>
</div>

<script>
(function() {
  'use strict';

  // ─── State ───
  var templateConfig = null;
  var layerStates = {}; // { layerId: { text, font, color, imageDataUrl } }
  var overlayCanvas = null;
  var overlayCtx = null;
  var productImageEl = null;
  var originalImageSrc = null;
  var loadedFonts = {};

  var productId = '{{ product.id }}';
  var productHandle = '{{ product.handle }}';
  var currentVariantId = '{{ product.selected_or_first_available_variant.id }}';

  // ─── Fetch template config ───
  function fetchTemplateConfig(variantId) {
    var apiUrl = '/apps/api/product-base?product_id=' + productId;
    if (variantId) apiUrl += '&variant_id=' + variantId;
    if (productHandle) apiUrl += '&handle=' + encodeURIComponent(productHandle);

    fetch(apiUrl)
      .then(function(r) { return r.json(); })
      .then(function(data) {
        console.log('[Customizer] Template config:', data);
        document.getElementById('pc-loading').style.display = 'none';

        if (!data.found || !data.template) {
          document.getElementById('pc-not-configured').style.display = 'block';
          return;
        }

        templateConfig = data.template;
        loadGoogleFonts(templateConfig.fonts || []);
        buildUI();
        initOverlay();
        setupVariantListener();

        // Swap to mockup image if available
        if (templateConfig.currentMockupUrl && productImageEl) {
          swapProductImage(templateConfig.currentMockupUrl);
        }
      })
      .catch(function(err) {
        console.warn('[Customizer] Failed to fetch config:', err);
        document.getElementById('pc-loading').style.display = 'none';
        document.getElementById('pc-not-configured').style.display = 'block';
      });
  }

  // ─── Load Google Fonts ───
  function loadGoogleFonts(fonts) {
    if (!fonts || fonts.length === 0) return;
    var families = fonts
      .filter(function(f) { return f.googleFontName; })
      .map(function(f) { return f.googleFontName.replace(/ /g, '+'); });
    if (families.length === 0) return;

    var link = document.createElement('link');
    link.rel = 'stylesheet';
    link.href = 'https://fonts.googleapis.com/css2?family=' +
      families.join('&family=') + '&display=swap';
    document.head.appendChild(link);
  }

  // ─── Build dynamic UI from template layers ───
  function buildUI() {
    var container = document.getElementById('pc-layers-container');
    container.innerHTML = '';
    container.style.display = 'block';

    var layers = templateConfig.layers || [];
    layers.forEach(function(layer) {
      if (!layer.customerEditable) return;

      // Initialize layer state
      layerStates[layer.id] = {
        type: layer.type,
        text: '',
        font: layer.defaultFont || (layer.fonts && layer.fonts[0] ? layer.fonts[0].key : 'script'),
        color: layer.defaultColor || '#000000',
        imageDataUrl: null,
        label: layer.label,
        position: layer.position,
        maxChars: layer.maxChars,
      };

      if (layer.type === 'text') {
        buildTextLayer(container, layer);
      } else if (layer.type === 'image') {
        buildImageLayer(container, layer);
      }
    });
  }

  // ─── Build text layer UI ───
  function buildTextLayer(container, layer) {
    var maxChars = layer.maxChars || 20;
    var fonts = layer.fonts || templateConfig.fonts || [];
    var colors = templateConfig.threadColors || [];
    console.log('[Customizer] Thread colors for layer', layer.id, ':', colors.length, 'colors', colors);

    var html = '<div class="pc-customizer__field">';
    html += '<label class="pc-customizer__label">' + escapeHtml(layer.label) + ' (1-' + maxChars + ' characters)</label>';
    html += '<input type="text" class="pc-customizer__input" data-layer-id="' + layer.id + '" data-type="text" maxlength="' + maxChars + '" placeholder="' + escapeHtml(layer.placeholder || 'ABC') + '" autocomplete="off">';
    html += '<div class="pc-customizer__char-count"><span class="pc-char-count" data-layer-id="' + layer.id + '">0</span>/' + maxChars + '</div>';
    html += '</div>';

    // Font picker
    if (fonts.length > 1) {
      html += '<div class="pc-customizer__field">';
      html += '<label class="pc-customizer__label">Font Style</label>';
      html += '<div class="pc-customizer__fonts" data-layer-id="' + layer.id + '">';
      fonts.forEach(function(font, idx) {
        var isActive = (font.key === (layer.defaultFont || fonts[0].key)) ? ' active' : '';
        html += '<button type="button" class="pc-customizer__font-btn' + isActive + '" data-font-key="' + font.key + '" data-layer-id="' + layer.id + '">';
        html += '<span class="pc-customizer__font-preview" style="font-family: ' + font.cssFontFamily + ';">ABC</span>';
        html += '<span class="pc-customizer__font-name">' + escapeHtml(font.displayName) + '</span>';
        html += '</button>';
      });
      html += '</div></div>';
    }

    // Color picker (thread colors for embroidery, or custom)
    if (colors.length > 0) {
      html += '<div class="pc-customizer__field">';
      html += '<label class="pc-customizer__label">Thread Color</label>';
      html += '<div class="pc-customizer__colors" data-layer-id="' + layer.id + '">';
      colors.forEach(function(color, idx) {
        var isActive = (idx === 0 || color.hex === layer.defaultColor) ? ' active' : '';
        if (isActive && idx === 0 && !layer.defaultColor) {
          // Set default color to first color
          layerStates[layer.id].color = color.hex;
        }
        if (color.hex === layer.defaultColor) {
          layerStates[layer.id].color = color.hex;
        }
        html += '<div class="pc-customizer__color-swatch' + isActive + '" data-hex="' + color.hex + '" data-name="' + escapeHtml(color.name) + '" data-layer-id="' + layer.id + '" style="background-color: ' + color.hex + ';" title="' + escapeHtml(color.name) + '" role="button" tabindex="0"></div>';
      });
      html += '</div>';
      var defaultColorName = colors[0] ? colors[0].name : '';
      if (layer.defaultColor) {
        var dc = colors.find(function(c) { return c.hex === layer.defaultColor; });
        if (dc) defaultColorName = dc.name;
      }
      html += '<div class="pc-customizer__color-name" data-layer-id="' + layer.id + '">' + escapeHtml(defaultColorName) + '</div>';
      html += '</div>';
    }

    container.insertAdjacentHTML('beforeend', html);

    // Bind events after DOM insertion
    setTimeout(function() {
      bindTextLayerEvents(layer);
    }, 0);
  }

  // ─── Build image upload layer UI ───
  function buildImageLayer(container, layer) {
    var acceptTypes = (layer.acceptedFileTypes || ['image/png', 'image/jpeg']).join(',');
    var maxMb = layer.maxFileSizeMb || 10;

    var html = '<div class="pc-customizer__field">';
    html += '<label class="pc-customizer__label">' + escapeHtml(layer.label) + '</label>';
    html += '<div class="pc-customizer__upload-zone" data-layer-id="' + layer.id + '">';
    html += '<img class="pc-customizer__upload-preview" data-layer-id="' + layer.id + '" alt="Upload preview">';
    html += '<div class="pc-customizer__upload-text">Click or drag to upload an image<br><small>Max ' + maxMb + 'MB, PNG or JPEG</small></div>';
    html += '<input type="file" class="pc-customizer__upload-input" data-layer-id="' + layer.id + '" accept="' + acceptTypes + '">';
    html += '</div></div>';

    container.insertAdjacentHTML('beforeend', html);

    setTimeout(function() {
      bindImageLayerEvents(layer);
    }, 0);
  }

  // ─── Bind text layer events ───
  function bindTextLayerEvents(layer) {
    var input = document.querySelector('.pc-customizer__input[data-layer-id="' + layer.id + '"]');
    var charCountEl = document.querySelector('.pc-char-count[data-layer-id="' + layer.id + '"]');
    var maxChars = layer.maxChars || 20;

    if (input) {
      input.addEventListener('input', function() {
        var val = this.value.replace(/[^a-zA-Z0-9 ]/g, '').toUpperCase().slice(0, maxChars);
        this.value = val;
        layerStates[layer.id].text = val;
        if (charCountEl) charCountEl.textContent = val.length;
        renderPreview();
      });
    }

    // Font buttons
    document.querySelectorAll('.pc-customizer__font-btn[data-layer-id="' + layer.id + '"]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.pc-customizer__font-btn[data-layer-id="' + layer.id + '"]').forEach(function(b) { b.classList.remove('active'); });
        this.classList.add('active');
        layerStates[layer.id].font = this.dataset.fontKey;
        renderPreview();
      });
    });

    // Color swatches
    document.querySelectorAll('.pc-customizer__color-swatch[data-layer-id="' + layer.id + '"]').forEach(function(swatch) {
      swatch.addEventListener('click', function() {
        document.querySelectorAll('.pc-customizer__color-swatch[data-layer-id="' + layer.id + '"]').forEach(function(s) { s.classList.remove('active'); });
        this.classList.add('active');
        layerStates[layer.id].color = this.dataset.hex;
        var nameEl = document.querySelector('.pc-customizer__color-name[data-layer-id="' + layer.id + '"]');
        if (nameEl) nameEl.textContent = this.dataset.name;
        renderPreview();
      });
    });
  }

  // ─── Bind image layer events ───
  function bindImageLayerEvents(layer) {
    var zone = document.querySelector('.pc-customizer__upload-zone[data-layer-id="' + layer.id + '"]');
    var input = document.querySelector('.pc-customizer__upload-input[data-layer-id="' + layer.id + '"]');
    var preview = document.querySelector('.pc-customizer__upload-preview[data-layer-id="' + layer.id + '"]');

    if (!zone || !input) return;

    zone.addEventListener('click', function() { input.click(); });

    zone.addEventListener('dragover', function(e) {
      e.preventDefault();
      zone.style.borderColor = '#333';
    });
    zone.addEventListener('dragleave', function() {
      zone.style.borderColor = '#ccc';
    });
    zone.addEventListener('drop', function(e) {
      e.preventDefault();
      zone.style.borderColor = '#ccc';
      if (e.dataTransfer.files.length > 0) {
        handleImageFile(layer.id, e.dataTransfer.files[0], preview, zone);
      }
    });

    input.addEventListener('change', function() {
      if (this.files.length > 0) {
        handleImageFile(layer.id, this.files[0], preview, zone);
      }
    });
  }

  function handleImageFile(layerId, file, previewEl, zoneEl) {
    var maxMb = 10;
    var layerConfig = (templateConfig.layers || []).find(function(l) { return l.id === layerId; });
    if (layerConfig) maxMb = layerConfig.maxFileSizeMb || 10;

    if (file.size > maxMb * 1024 * 1024) {
      alert('File too large. Maximum size is ' + maxMb + 'MB.');
      return;
    }

    var reader = new FileReader();
    reader.onload = function(e) {
      layerStates[layerId].imageDataUrl = e.target.result;
      if (previewEl) {
        previewEl.src = e.target.result;
        previewEl.classList.add('visible');
      }
      if (zoneEl) zoneEl.classList.add('has-file');
      renderPreview();
    };
    reader.readAsDataURL(file);
  }

  // ─── Build server-side preview image URL ───
  // Generates a URL pointing to /apps/api/preview which composites
  // the monogram text onto the real product mockup using sharp (server-side).
  // This avoids CORS tainted-canvas issues that break client-side snapshots.

  function buildPreviewImageUrl() {
    // Find the first text layer with content
    var firstText = null;
    var layerIds = Object.keys(layerStates);
    for (var i = 0; i < layerIds.length; i++) {
      var ls = layerStates[layerIds[i]];
      if (ls && ls.type === 'text' && ls.text) {
        firstText = ls;
        break;
      }
    }
    if (!firstText) return '';

    // Detect the currently selected color variant
    var selectedColor = detectSelectedColorName();

    var params = new URLSearchParams();
    params.set('text', firstText.text);
    params.set('style', firstText.font || 'block');
    params.set('color', firstText.color || '#000000');
    params.set('handle', '{{ product.handle }}');
    params.set('product_id', '{{ product.id }}');
    if (selectedColor) params.set('color_name', selectedColor);
    params.set('format', 'image');

    return '/apps/api/preview?' + params.toString();
  }

  // ─── Cart drawer thumbnail swap ───
  // After adding to cart, watch for the cart drawer to open and swap
  // the thumbnail images for personalized items.
  function setupCartDrawerObserver() {
    // Watch for cart drawer opening (Dawn theme uses cart-drawer or cart-notification)
    var observer = new MutationObserver(function() {
      setTimeout(swapCartThumbnails, 500);
    });

    // Observe body for cart drawer appearance
    observer.observe(document.body, { childList: true, subtree: true, attributes: true });
  }

  function swapCartThumbnails() {
    // Fetch cart data to find items with our server-side preview URL
    fetch('/cart.js')
      .then(function(r) { return r.json(); })
      .then(function(cart) {
        if (!cart.items) return;

        // Find cart drawer/notification images
        var cartImages = document.querySelectorAll(
          'cart-drawer img, cart-notification img, .cart-drawer img, ' +
          '.cart-notification img, #cart-drawer img, .drawer img, ' +
          '.cart-item img, .cart__image, [data-cart-item] img, ' +
          'cart-drawer-items img, .cart-drawer__item img'
        );

        cart.items.forEach(function(item, idx) {
          if (!item.properties || !item.properties._preview_image) return;

          // Try to match by position (items render in same order)
          if (cartImages[idx]) {
            cartImages[idx].src = item.properties._preview_image;
            if (cartImages[idx].srcset) cartImages[idx].removeAttribute('srcset');
            console.log('[Customizer] Swapped cart thumbnail for item', idx);
          }
        });
      })
      .catch(function(e) {
        console.warn('[Customizer] Could not swap cart thumbnails:', e);
      });
  }

  // Start observing cart drawer
  setupCartDrawerObserver();

  // ─── Monkey-patch fetch for cart/add.js ───
  var originalFetch = window.fetch;
  window.fetch = function(url, options) {
    var urlStr = (typeof url === 'string') ? url : (url && url.url ? url.url : '');
    if (urlStr.indexOf('/cart/add') !== -1 && options && options.method && options.method.toUpperCase() === 'POST') {
      var hasPersonalization = false;
      var layerIds = Object.keys(layerStates);
      for (var i = 0; i < layerIds.length; i++) {
        var ls = layerStates[layerIds[i]];
        if ((ls.type === 'text' && ls.text) || (ls.type === 'image' && ls.imageDataUrl)) {
          hasPersonalization = true;
          break;
        }
      }

      if (hasPersonalization) {
        try {
          var body = options.body;
          if (body instanceof FormData) {
            // Add personalization data as JSON blob
            var persData = {};
            layerIds.forEach(function(lid) {
              var ls = layerStates[lid];
              if (ls.type === 'text' && ls.text) {
                persData[lid] = { type: 'text', text: ls.text, font: ls.font, color: ls.color, label: ls.label };
              } else if (ls.type === 'image' && ls.imageDataUrl) {
                persData[lid] = { type: 'image', hasImage: true, label: ls.label };
              }
            });

            body.append('properties[_personalization_data]', JSON.stringify(persData));
            body.append('properties[_template_id]', templateConfig ? templateConfig.id : '');
            body.append('properties[_product_base]', templateConfig ? templateConfig.productBaseSlug : '');
            body.append('properties[_technique]', templateConfig ? templateConfig.technique : '');
            body.append('properties[_placement]', templateConfig ? templateConfig.placementKey : '');

            // Legacy compat: also add monogram fields from first text layer
            var firstText = null;
            layerIds.forEach(function(lid) {
              if (!firstText && layerStates[lid].type === 'text' && layerStates[lid].text) {
                firstText = layerStates[lid];
              }
            });
            if (firstText) {
              body.append('properties[_monogram_text]', firstText.text);
              body.append('properties[_monogram_style]', firstText.font);
              body.append('properties[_thread_color]', firstText.color);
            }

            // Set server-side preview image URL for cart thumbnail
            var previewUrl = buildPreviewImageUrl();
            if (previewUrl) {
              body.append('properties[_preview_image]', previewUrl);
            }

            // Visible personalization summary for checkout/order confirmation
            var summaryParts = [];
            layerIds.forEach(function(lid) {
              var ls = layerStates[lid];
              if (ls.type === 'text' && ls.text) {
                summaryParts.push(ls.text + ' (' + ls.font + ', ' + ls.color + ')');
              } else if (ls.type === 'image' && ls.imageDataUrl) {
                summaryParts.push('Custom Image');
              }
            });
            if (summaryParts.length > 0) {
              body.append('properties[Personalization]', summaryParts.join('; '));
            }

            console.log('[Customizer] Injected properties into FormData cart/add.js');
          } else if (typeof body === 'string') {
            var parsed = JSON.parse(body);
            if (!parsed.properties) parsed.properties = {};

            var persData2 = {};
            layerIds.forEach(function(lid) {
              var ls = layerStates[lid];
              if (ls.type === 'text' && ls.text) {
                persData2[lid] = { type: 'text', text: ls.text, font: ls.font, color: ls.color, label: ls.label };
              } else if (ls.type === 'image' && ls.imageDataUrl) {
                persData2[lid] = { type: 'image', hasImage: true, label: ls.label };
              }
            });

            parsed.properties['_personalization_data'] = JSON.stringify(persData2);
            parsed.properties['_template_id'] = templateConfig ? templateConfig.id : '';
            parsed.properties['_product_base'] = templateConfig ? templateConfig.productBaseSlug : '';
            parsed.properties['_technique'] = templateConfig ? templateConfig.technique : '';
            parsed.properties['_placement'] = templateConfig ? templateConfig.placementKey : '';

            var firstText2 = null;
            layerIds.forEach(function(lid) {
              if (!firstText2 && layerStates[lid].type === 'text' && layerStates[lid].text) {
                firstText2 = layerStates[lid];
              }
            });
            if (firstText2) {
              parsed.properties['_monogram_text'] = firstText2.text;
              parsed.properties['_monogram_style'] = firstText2.font;
              parsed.properties['_thread_color'] = firstText2.color;
            }

            var previewUrl2 = buildPreviewImageUrl();
            if (previewUrl2) {
              parsed.properties['_preview_image'] = previewUrl2;
            }

            var summaryParts2 = [];
            layerIds.forEach(function(lid) {
              var ls = layerStates[lid];
              if (ls.type === 'text' && ls.text) {
                summaryParts2.push(ls.text + ' (' + ls.font + ', ' + ls.color + ')');
              } else if (ls.type === 'image' && ls.imageDataUrl) {
                summaryParts2.push('Custom Image');
              }
            });
            if (summaryParts2.length > 0) {
              parsed.properties['Personalization'] = summaryParts2.join('; ');
            }

            options.body = JSON.stringify(parsed);
            console.log('[Customizer] Injected properties into JSON cart/add.js');
          }
        } catch (e) {
          console.warn('[Customizer] Could not inject properties:', e);
        }
      }
    }
    return originalFetch.apply(this, arguments);
  };

  // ─── Product image overlay ───
  function swapProductImage(imageUrl) {
    if (!productImageEl) return;
    if (!originalImageSrc) originalImageSrc = productImageEl.src;
    productImageEl.src = imageUrl;
    if (productImageEl.srcset) productImageEl.srcset = imageUrl;
    console.log('[Customizer] Swapped product image to mockup:', imageUrl);
  }

  function initOverlay() {
    var selectors = [
      '.product__media img',
      '.product-media-container img',
      '.product__media-item img',
      '.product-featured-media img',
      '.product__main-photos img',
      '.product-single__photo img',
      '.product__photo img',
      'media-gallery img',
      '.product--media img',
      '[data-product-media-type="image"] img',
      '.product-image-container img',
      '.product__media-wrapper img',
      '.product__media-list img:first-of-type',
      'product-info media-gallery img',
      '.media-gallery img'
    ];

    for (var i = 0; i < selectors.length; i++) {
      var img = document.querySelector(selectors[i]);
      if (img && img.naturalWidth > 100) {
        productImageEl = img;
        break;
      }
    }

    if (!productImageEl) {
      var allImgs = document.querySelectorAll('img');
      var largest = null;
      var largestArea = 0;
      allImgs.forEach(function(img) {
        var area = img.offsetWidth * img.offsetHeight;
        if (area > largestArea && img.offsetWidth > 200) {
          largest = img;
          largestArea = area;
        }
      });
      productImageEl = largest;
    }

    if (!productImageEl) {
      console.warn('[Customizer] Could not find product image for overlay');
      return;
    }

    originalImageSrc = productImageEl.src;

    var parent = productImageEl.parentElement;
    if (window.getComputedStyle(parent).position === 'static') {
      parent.style.position = 'relative';
    }

    overlayCanvas = document.createElement('canvas');
    overlayCanvas.className = 'monogram-overlay-canvas';
    parent.appendChild(overlayCanvas);
    overlayCtx = overlayCanvas.getContext('2d');

    positionOverlay();
    window.addEventListener('resize', positionOverlay);

    new MutationObserver(function() {
      setTimeout(positionOverlay, 100);
    }).observe(parent, { childList: true, subtree: true, attributes: true });

    // Swap to mockup if available — try variant-specific first, then default
    if (templateConfig) {
      var initialMockup = templateConfig.currentMockupUrl;
      // Try to get the correct color variant mockup on initial load
      if (templateConfig.variantImages) {
        var initByVariant = templateConfig.variantImages[currentVariantId];
        if (initByVariant) {
          initialMockup = initByVariant;
        } else {
          var initColor = detectSelectedColorName();
          if (initColor) {
            var initByColor = templateConfig.variantImages[initColor] || templateConfig.variantImages[initColor.toLowerCase()];
            if (initByColor) initialMockup = initByColor;
          }
        }
      }
      if (initialMockup) {
        swapProductImage(initialMockup);
      }
    }
  }

  function positionOverlay() {
    if (!overlayCanvas || !productImageEl) return;
    var rect = productImageEl.getBoundingClientRect();
    var parentRect = productImageEl.parentElement.getBoundingClientRect();

    overlayCanvas.width = rect.width;
    overlayCanvas.height = rect.height;
    overlayCanvas.style.left = (rect.left - parentRect.left) + 'px';
    overlayCanvas.style.top = (rect.top - parentRect.top) + 'px';
    overlayCanvas.style.width = rect.width + 'px';
    overlayCanvas.style.height = rect.height + 'px';

    renderPreview();
  }

  // ─── Canvas preview rendering ───
  function renderPreview() {
    if (!overlayCanvas || !overlayCtx) return;

    var w = overlayCanvas.width;
    var h = overlayCanvas.height;
    overlayCtx.clearRect(0, 0, w, h);

    if (!templateConfig) return;

    var printArea = templateConfig.printArea || { x: 25, y: 15, width: 50, height: 35 };
    var paX = w * (printArea.x / 100);
    var paY = h * (printArea.y / 100);
    var paW = w * (printArea.width / 100);
    var paH = h * (printArea.height / 100);

    // Render each layer
    var layerIds = Object.keys(layerStates);
    layerIds.forEach(function(lid) {
      var ls = layerStates[lid];
      if (!ls) return;

      // Calculate layer position within print area
      var pos = ls.position || { x: 10, y: 10, width: 80, height: 80 };
      var lx = paX + paW * (pos.x / 100);
      var ly = paY + paH * (pos.y / 100);
      var lw = paW * (pos.width / 100);
      var lh = paH * (pos.height / 100);

      if (ls.type === 'text' && ls.text) {
        renderTextLayer(ls, lx, ly, lw, lh);
      } else if (ls.type === 'image' && ls.imageDataUrl) {
        renderImageLayer(ls, lx, ly, lw, lh);
      }
    });
  }

  function renderTextLayer(ls, x, y, w, h) {
    var centerX = x + w / 2;
    var centerY = y + h / 2;

    // Find the font config
    var fontConfig = null;
    if (templateConfig && templateConfig.fonts) {
      fontConfig = templateConfig.fonts.find(function(f) { return f.key === ls.font; });
    }
    var fontFamily = fontConfig ? fontConfig.cssFontFamily : "'Montserrat', sans-serif";

    overlayCtx.fillStyle = ls.color;
    overlayCtx.textAlign = 'center';
    overlayCtx.textBaseline = 'middle';
    overlayCtx.shadowColor = 'rgba(0,0,0,0.15)';
    overlayCtx.shadowBlur = 2;
    overlayCtx.shadowOffsetX = 1;
    overlayCtx.shadowOffsetY = 1;

    var fontSize = Math.min(w * 0.5, h * 0.85);

    // For monogram-style (3 chars, middle larger) in block fonts
    if (ls.text.length === 3 && ls.font !== 'script' && ls.font !== 'monogram_classic') {
      var bigSize = fontSize * 1.35;
      var sideSize = fontSize * 0.85;
      var spacing = w * 0.28;

      overlayCtx.font = 'bold ' + bigSize + 'px ' + fontFamily;
      overlayCtx.fillText(ls.text[1], centerX, centerY);

      overlayCtx.font = 'bold ' + sideSize + 'px ' + fontFamily;
      overlayCtx.fillText(ls.text[0], centerX - spacing, centerY);
      overlayCtx.fillText(ls.text[2], centerX + spacing, centerY);
    } else {
      overlayCtx.font = fontSize + 'px ' + fontFamily;
      overlayCtx.fillText(ls.text, centerX, centerY);
    }

    // Reset shadow
    overlayCtx.shadowColor = 'transparent';
    overlayCtx.shadowBlur = 0;
    overlayCtx.shadowOffsetX = 0;
    overlayCtx.shadowOffsetY = 0;
  }

  function renderImageLayer(ls, x, y, w, h) {
    var img = new Image();
    img.onload = function() {
      // Fit image within the layer bounds
      var scale = Math.min(w / img.width, h / img.height);
      var drawW = img.width * scale;
      var drawH = img.height * scale;
      var drawX = x + (w - drawW) / 2;
      var drawY = y + (h - drawH) / 2;
      overlayCtx.drawImage(img, drawX, drawY, drawW, drawH);
    };
    img.src = ls.imageDataUrl;
  }

  // ─── Variant change listener ───
  function setupVariantListener() {
    // 1. Standard variant:change event
    document.addEventListener('variant:change', function(e) {
      var detail = e.detail || {};
      var newVariantId = detail.variant ? detail.variant.id : null;
      if (newVariantId) handleVariantChange(String(newVariantId));
    });

    // 2. URL polling for variant changes
    var lastUrl = window.location.href;
    setInterval(function() {
      if (window.location.href !== lastUrl) {
        lastUrl = window.location.href;
        var urlParams = new URLSearchParams(window.location.search);
        var newVariantId = urlParams.get('variant');
        if (newVariantId) handleVariantChange(newVariantId);
      }
    }, 500);

    // 3. Direct change listener on hidden variant inputs
    document.querySelectorAll('input[name="id"], select[name="id"]').forEach(function(el) {
      el.addEventListener('change', function() { handleVariantChange(this.value); });
    });

    // 4. MutationObserver on variant containers
    document.querySelectorAll('variant-radios, variant-selects, fieldset').forEach(function(el) {
      new MutationObserver(function() {
        var selectedInput = el.querySelector('input[name="id"]:checked') || el.querySelector('select[name="id"]');
        if (selectedInput) handleVariantChange(selectedInput.value);
      }).observe(el, { subtree: true, attributes: true, childList: true });
    });

    // 5. ★ Direct click listener on Color radio inputs (Dawn theme)
    //    This catches the case where the hidden input[name="id"] doesn't trigger change
    document.querySelectorAll('input[name="Color"], input[name="color"], input[name="Colour"]').forEach(function(radio) {
      radio.addEventListener('change', function() {
        console.log('[Customizer] Color radio changed to:', this.value);
        // The variant ID may not be updated yet, so use color name directly
        if (templateConfig && templateConfig.variantImages) {
          var colorName = this.value;
          var variantImage = templateConfig.variantImages[colorName] ||
                             templateConfig.variantImages[colorName.toLowerCase()];
          if (variantImage) {
            swapProductImage(variantImage);
            console.log('[Customizer] Swapped mockup by color radio:', colorName);
          }
        }
        renderPreview();
      });
    });

    // 6. ★ Watch for hidden input[name="id"] value changes via MutationObserver
    //    Dawn theme updates this hidden input when variant changes
    document.querySelectorAll('form input[name="id"][type="hidden"]').forEach(function(hiddenInput) {
      new MutationObserver(function(mutations) {
        mutations.forEach(function(m) {
          if (m.type === 'attributes' && m.attributeName === 'value') {
            var newVal = hiddenInput.value;
            if (newVal) handleVariantChange(newVal);
          }
        });
      }).observe(hiddenInput, { attributes: true, attributeFilter: ['value'] });
    });
  }

  function handleVariantChange(newVariantId) {
    if (newVariantId === currentVariantId) return;
    currentVariantId = newVariantId;
    console.log('[Customizer] Variant changed to:', newVariantId);

    if (templateConfig && templateConfig.variantImages) {
      var variantImage = templateConfig.variantImages[newVariantId];

      // If no direct match by Shopify variant ID, try to find by color name
      if (!variantImage) {
        var colorName = detectSelectedColorName();
        if (colorName) {
          variantImage = templateConfig.variantImages[colorName] ||
                         templateConfig.variantImages[colorName.toLowerCase()];
          console.log('[Customizer] Matched by color name:', colorName, !!variantImage);
        }
      }

      if (variantImage) {
        swapProductImage(variantImage);
      } else if (templateConfig.defaultMockupUrl) {
        swapProductImage(templateConfig.defaultMockupUrl);
      }
    }
    renderPreview();
  }

  // Detect the currently selected color name from the variant selector UI
  function detectSelectedColorName() {
    // Method 1 (BEST): Dawn theme — fieldset with legend "Color" containing checked radio
    var fieldsets = document.querySelectorAll('fieldset');
    for (var j = 0; j < fieldsets.length; j++) {
      var legend = fieldsets[j].querySelector('legend');
      if (legend && legend.textContent.toLowerCase().indexOf('color') !== -1) {
        var checked = fieldsets[j].querySelector('input:checked');
        if (checked && checked.value) {
          console.log('[Customizer] detectColor via fieldset legend:', checked.value);
          return checked.value;
        }
      }
    }

    // Method 2: Radio with name="Color" or name="color"
    var colorRadio = document.querySelector('input[type="radio"][name="Color"]:checked') ||
                     document.querySelector('input[type="radio"][name="color"]:checked') ||
                     document.querySelector('input[type="radio"][name="Colour"]:checked');
    if (colorRadio && colorRadio.value) {
      console.log('[Customizer] detectColor via named radio:', colorRadio.value);
      return colorRadio.value;
    }

    // Method 3: Check select elements for color option
    var selects = document.querySelectorAll('select');
    for (var i = 0; i < selects.length; i++) {
      var sel = selects[i];
      var labelEl = document.querySelector('label[for="' + sel.id + '"]');
      var labelText = labelEl ? labelEl.textContent.toLowerCase() : '';
      if (labelText.indexOf('color') !== -1 || labelText.indexOf('colour') !== -1) {
        return sel.options[sel.selectedIndex].text.trim();
      }
    }

    // Method 4: Look for a swatch or option button with aria-checked or .active class
    var activeSwatches = document.querySelectorAll('[aria-checked="true"], .swatch--active, .is-active');
    for (var k = 0; k < activeSwatches.length; k++) {
      var swatch = activeSwatches[k];
      var title = swatch.getAttribute('title') || swatch.getAttribute('aria-label') || swatch.getAttribute('data-value');
      if (title) return title;
    }

    // Method 5: Any checked radio as last resort (but only if in variant-radios)
    var variantRadios = document.querySelector('variant-radios');
    if (variantRadios) {
      var anyChecked = variantRadios.querySelector('input[type="radio"]:checked');
      if (anyChecked && anyChecked.value) return anyChecked.value;
    }

    return null;
  }

  // ─── Helpers ───
  function escapeHtml(str) {
    var div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  // ─── Init ───
  function initWhenReady() {
    if (document.fonts && document.fonts.ready) {
      document.fonts.ready.then(function() {
        setTimeout(function() { fetchTemplateConfig(currentVariantId); }, 300);
      });
    } else {
      setTimeout(function() { fetchTemplateConfig(currentVariantId); }, 800);
    }
  }

  if (document.readyState === 'complete') {
    initWhenReady();
  } else {
    window.addEventListener('load', initWhenReady);
  }
  document.addEventListener('shopify:section:load', initWhenReady);
})();
</script>

{% schema %}
{
  "name": "Product Customizer",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Personalize Your Product"
    }
  ]
}
{% endschema %}
