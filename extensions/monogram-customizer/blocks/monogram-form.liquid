{% comment %}
  Monogram Customizer Block
  Renders a personalization form on the product page with:
  - Text input (1-3 characters)
  - Font style selector (script / block)
  - Thread color picker (Printful's 15 embroidery colors)
  - Live canvas preview
  Saves selections as hidden line item properties.
{% endcomment %}

<style>
  .monogram-customizer {
    margin: 16px 0;
    padding: 20px;
    border: 1px solid #e5e5e5;
    border-radius: 8px;
    background: #fafafa;
    font-family: inherit;
  }

  .monogram-customizer__title {
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 16px;
    color: #1a1a1a;
  }

  .monogram-customizer__field {
    margin-bottom: 16px;
  }

  .monogram-customizer__label {
    display: block;
    font-size: 13px;
    font-weight: 500;
    margin-bottom: 6px;
    color: #333;
  }

  .monogram-customizer__input {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid #ccc;
    border-radius: 6px;
    font-size: 18px;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 4px;
    box-sizing: border-box;
  }

  .monogram-customizer__input:focus {
    outline: none;
    border-color: #333;
  }

  .monogram-customizer__char-count {
    font-size: 11px;
    color: #999;
    text-align: right;
    margin-top: 4px;
  }

  .monogram-customizer__styles {
    display: flex;
    gap: 8px;
  }

  .monogram-customizer__style-btn {
    flex: 1;
    padding: 10px;
    border: 2px solid #ddd;
    border-radius: 6px;
    background: white;
    cursor: pointer;
    text-align: center;
    transition: all 0.2s;
  }

  .monogram-customizer__style-btn:hover {
    border-color: #999;
  }

  .monogram-customizer__style-btn.active {
    border-color: #333;
    background: #f5f5f5;
  }

  .monogram-customizer__style-label {
    display: block;
    font-size: 12px;
    font-weight: 500;
    margin-top: 4px;
  }

  .monogram-customizer__style-preview {
    font-size: 20px;
    line-height: 1.2;
  }

  .monogram-customizer__style-btn[data-style="script"] .monogram-customizer__style-preview {
    font-family: 'Great Vibes', cursive, serif;
    font-style: italic;
  }

  .monogram-customizer__style-btn[data-style="block"] .monogram-customizer__style-preview {
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    letter-spacing: 3px;
  }

  .monogram-customizer__colors {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .monogram-customizer__color-swatch {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 2px solid transparent;
    cursor: pointer;
    transition: all 0.2s;
    position: relative;
  }

  .monogram-customizer__color-swatch:hover {
    transform: scale(1.15);
  }

  .monogram-customizer__color-swatch.active {
    border-color: #333;
    box-shadow: 0 0 0 2px white, 0 0 0 4px #333;
  }

  .monogram-customizer__color-swatch[data-color="#FFFFFF"] {
    border-color: #ddd;
  }

  .monogram-customizer__color-name {
    font-size: 11px;
    color: #666;
    margin-top: 6px;
  }

  .monogram-customizer__preview-wrap {
    margin-top: 16px;
    text-align: center;
  }

  .monogram-customizer__preview-label {
    font-size: 12px;
    color: #999;
    margin-bottom: 8px;
  }

  .monogram-customizer__preview-canvas {
    width: 100%;
    max-width: 320px;
    height: auto;
    border: 1px solid #e5e5e5;
    border-radius: 6px;
    background: white;
  }

  .monogram-customizer__error {
    color: #cc0000;
    font-size: 12px;
    margin-top: 4px;
    display: none;
  }

  .monogram-customizer__error.visible {
    display: block;
  }
</style>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Montserrat:wght@700&display=swap" rel="stylesheet">

<div class="monogram-customizer" id="monogram-customizer">
  <div class="monogram-customizer__title">{{ block.settings.title }}</div>

  <!-- Text Input -->
  <div class="monogram-customizer__field">
    <label class="monogram-customizer__label" for="monogram-text">Monogram Text (1-3 letters)</label>
    <input
      type="text"
      id="monogram-text"
      class="monogram-customizer__input"
      maxlength="3"
      placeholder="ABC"
      autocomplete="off"
    >
    <div class="monogram-customizer__char-count"><span id="char-count">0</span>/3</div>
    <div class="monogram-customizer__error" id="monogram-error">Please enter 1-3 letters for your monogram</div>
  </div>

  <!-- Font Style -->
  <div class="monogram-customizer__field">
    <label class="monogram-customizer__label">Font Style</label>
    <div class="monogram-customizer__styles">
      <button type="button" class="monogram-customizer__style-btn active" data-style="script">
        <span class="monogram-customizer__style-preview">ABC</span>
        <span class="monogram-customizer__style-label">Script</span>
      </button>
      <button type="button" class="monogram-customizer__style-btn" data-style="block">
        <span class="monogram-customizer__style-preview">ABC</span>
        <span class="monogram-customizer__style-label">Block</span>
      </button>
    </div>
  </div>

  <!-- Thread Color -->
  <div class="monogram-customizer__field">
    <label class="monogram-customizer__label">Thread Color</label>
    <div class="monogram-customizer__colors" id="color-picker">
      {% assign colors = "#FFFFFF,White|#000000,Black|#96A1A8,Grey|#A67843,Brown|#FFCC00,Gold|#E8D075,Cream|#CC3333,Red|#CC6699,Pink|#800020,Maroon|#FF6633,Orange|#3399FF,Royal Blue|#003366,Navy|#336633,Forest Green|#99CCCC,Light Blue|#800080,Purple" | split: "|" %}
      {% for color_pair in colors %}
        {% assign parts = color_pair | split: "," %}
        {% assign hex = parts[0] %}
        {% assign name = parts[1] %}
        <div
          class="monogram-customizer__color-swatch{% if hex == '#000000' %} active{% endif %}"
          data-color="{{ hex }}"
          data-name="{{ name }}"
          style="background-color: {{ hex }};"
          title="{{ name }}"
          role="button"
          tabindex="0"
        ></div>
      {% endfor %}
    </div>
    <div class="monogram-customizer__color-name" id="color-name">Black</div>
  </div>

  <!-- Live Preview -->
  <div class="monogram-customizer__preview-wrap">
    <div class="monogram-customizer__preview-label">Preview</div>
    <canvas id="monogram-preview" class="monogram-customizer__preview-canvas" width="660" height="240"></canvas>
  </div>

  <!-- Hidden inputs for line item properties -->
  <input type="hidden" name="properties[_monogram_text]" id="prop-monogram-text" value="">
  <input type="hidden" name="properties[_monogram_style]" id="prop-monogram-style" value="script">
  <input type="hidden" name="properties[_thread_color]" id="prop-thread-color" value="#000000">
</div>

<script>
  (function() {
    const textInput = document.getElementById('monogram-text');
    const charCount = document.getElementById('char-count');
    const errorEl = document.getElementById('monogram-error');
    const colorPicker = document.getElementById('color-picker');
    const colorNameEl = document.getElementById('color-name');
    const canvas = document.getElementById('monogram-preview');
    const ctx = canvas.getContext('2d');

    // Hidden properties
    const propText = document.getElementById('prop-monogram-text');
    const propStyle = document.getElementById('prop-monogram-style');
    const propColor = document.getElementById('prop-thread-color');

    let currentStyle = 'script';
    let currentColor = '#000000';
    let currentText = '';

    // Style buttons
    document.querySelectorAll('.monogram-customizer__style-btn').forEach(btn => {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.monogram-customizer__style-btn').forEach(b => b.classList.remove('active'));
        this.classList.add('active');
        currentStyle = this.dataset.style;
        propStyle.value = currentStyle;
        renderPreview();
      });
    });

    // Color swatches
    colorPicker.addEventListener('click', function(e) {
      const swatch = e.target.closest('.monogram-customizer__color-swatch');
      if (!swatch) return;
      document.querySelectorAll('.monogram-customizer__color-swatch').forEach(s => s.classList.remove('active'));
      swatch.classList.add('active');
      currentColor = swatch.dataset.color;
      colorNameEl.textContent = swatch.dataset.name;
      propColor.value = currentColor;
      renderPreview();
    });

    // Text input
    textInput.addEventListener('input', function() {
      let val = this.value.replace(/[^a-zA-Z]/g, '').toUpperCase().slice(0, 3);
      this.value = val;
      currentText = val;
      charCount.textContent = val.length;
      propText.value = val;

      if (val.length === 0) {
        errorEl.classList.add('visible');
      } else {
        errorEl.classList.remove('visible');
      }

      renderPreview();
    });

    // Intercept add-to-cart if no monogram text
    const form = document.querySelector('form[action*="/cart/add"]') || document.querySelector('product-form form');
    if (form) {
      form.addEventListener('submit', function(e) {
        if (currentText.length === 0) {
          e.preventDefault();
          errorEl.classList.add('visible');
          textInput.focus();
        }
      });
    }

    // Canvas preview rendering
    function renderPreview() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);

      // Background
      ctx.fillStyle = '#f9f9f9';
      ctx.fillRect(0, 0, canvas.width, canvas.height);

      if (!currentText) {
        ctx.fillStyle = '#ccc';
        ctx.font = '16px sans-serif';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText('Enter your initials above', canvas.width / 2, canvas.height / 2);
        return;
      }

      ctx.fillStyle = currentColor;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';

      if (currentStyle === 'script') {
        ctx.font = '120px "Great Vibes", cursive';
        ctx.fillText(currentText, canvas.width / 2, canvas.height / 2 + 10);
      } else {
        // Block monogram: traditional style with larger center letter
        if (currentText.length === 3) {
          const centerX = canvas.width / 2;
          const centerY = canvas.height / 2;

          // Larger center letter
          ctx.font = '140px "Montserrat", sans-serif';
          ctx.fillText(currentText[1], centerX, centerY);

          // Smaller side letters
          ctx.font = '90px "Montserrat", sans-serif';
          ctx.fillText(currentText[0], centerX - 130, centerY);
          ctx.fillText(currentText[2], centerX + 130, centerY);
        } else {
          ctx.font = '120px "Montserrat", sans-serif';
          ctx.letterSpacing = '8px';
          ctx.fillText(currentText, canvas.width / 2, canvas.height / 2);
        }
      }
    }

    // Initial render
    renderPreview();
  })();
</script>

{% schema %}
{
  "name": "Monogram Customizer",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Personalize Your Hat"
    }
  ]
}
{% endschema %}
