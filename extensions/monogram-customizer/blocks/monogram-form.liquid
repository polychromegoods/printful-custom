{% comment %}
  Monogram Customizer Block
  Renders a personalization form on the product page with:
  - Text input (1-3 characters)
  - Font style selector (script / block)
  - Thread color picker (Printful's 15 embroidery colors)
  - Live preview overlaid on the product image
  - On add-to-cart: calls server API to generate a permanent preview image,
    then stores the URL as a visible line item property so it appears in
    cart, checkout, order confirmation, and admin.
{% endcomment %}

<style>
  .monogram-customizer {
    margin: 16px 0;
    padding: 20px;
    border: 1px solid #e5e5e5;
    border-radius: 8px;
    background: #fafafa;
    font-family: inherit;
  }

  .monogram-customizer__title {
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 16px;
    color: #1a1a1a;
  }

  .monogram-customizer__field {
    margin-bottom: 16px;
  }

  .monogram-customizer__label {
    display: block;
    font-size: 13px;
    font-weight: 500;
    margin-bottom: 6px;
    color: #333;
  }

  .monogram-customizer__input {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid #ccc;
    border-radius: 6px;
    font-size: 18px;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 4px;
    box-sizing: border-box;
  }

  .monogram-customizer__input:focus {
    outline: none;
    border-color: #333;
  }

  .monogram-customizer__char-count {
    font-size: 11px;
    color: #999;
    text-align: right;
    margin-top: 4px;
  }

  .monogram-customizer__styles {
    display: flex;
    gap: 8px;
  }

  .monogram-customizer__style-btn {
    flex: 1;
    padding: 10px;
    border: 2px solid #ddd;
    border-radius: 6px;
    background: white;
    cursor: pointer;
    text-align: center;
    transition: all 0.2s;
  }

  .monogram-customizer__style-btn:hover {
    border-color: #999;
  }

  .monogram-customizer__style-btn.active {
    border-color: #333;
    background: #f5f5f5;
  }

  .monogram-customizer__style-label {
    display: block;
    font-size: 12px;
    font-weight: 500;
    margin-top: 4px;
  }

  .monogram-customizer__style-preview {
    font-size: 20px;
    line-height: 1.2;
  }

  .monogram-customizer__style-btn[data-style="script"] .monogram-customizer__style-preview {
    font-family: 'Great Vibes', cursive, serif;
    font-style: italic;
  }

  .monogram-customizer__style-btn[data-style="block"] .monogram-customizer__style-preview {
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    letter-spacing: 3px;
  }

  .monogram-customizer__colors {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .monogram-customizer__color-swatch {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 2px solid transparent;
    cursor: pointer;
    transition: all 0.2s;
    position: relative;
  }

  .monogram-customizer__color-swatch:hover {
    transform: scale(1.15);
  }

  .monogram-customizer__color-swatch.active {
    border-color: #333;
    box-shadow: 0 0 0 2px white, 0 0 0 4px #333;
  }

  .monogram-customizer__color-swatch[data-color="#FFFFFF"] {
    border-color: #ddd;
  }

  .monogram-customizer__color-name {
    font-size: 11px;
    color: #666;
    margin-top: 6px;
  }

  .monogram-customizer__error {
    color: #cc0000;
    font-size: 12px;
    margin-top: 4px;
    display: none;
  }

  .monogram-customizer__error.visible {
    display: block;
  }

  /* Overlay canvas on product image */
  .monogram-overlay-canvas {
    position: absolute;
    pointer-events: none;
    z-index: 10;
  }

  /* Loading spinner for add-to-cart */
  .monogram-customizer__loading {
    display: none;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 8px;
    font-size: 13px;
    color: #666;
  }

  .monogram-customizer__loading.visible {
    display: flex;
  }

  .monogram-customizer__spinner {
    width: 16px;
    height: 16px;
    border: 2px solid #ddd;
    border-top-color: #333;
    border-radius: 50%;
    animation: monogram-spin 0.6s linear infinite;
  }

  @keyframes monogram-spin {
    to { transform: rotate(360deg); }
  }
</style>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Montserrat:wght@700&display=swap" rel="stylesheet">

<div class="monogram-customizer" id="monogram-customizer">
  <div class="monogram-customizer__title">{{ block.settings.title }}</div>

  <!-- Text Input -->
  <div class="monogram-customizer__field">
    <label class="monogram-customizer__label" for="monogram-text">Monogram Text (1-3 letters)</label>
    <input
      type="text"
      id="monogram-text"
      class="monogram-customizer__input"
      maxlength="3"
      placeholder="ABC"
      autocomplete="off"
    >
    <div class="monogram-customizer__char-count"><span id="char-count">0</span>/3</div>
    <div class="monogram-customizer__error" id="monogram-error">Please enter 1-3 letters for your monogram</div>
  </div>

  <!-- Font Style -->
  <div class="monogram-customizer__field">
    <label class="monogram-customizer__label">Font Style</label>
    <div class="monogram-customizer__styles">
      <button type="button" class="monogram-customizer__style-btn active" data-style="script">
        <span class="monogram-customizer__style-preview">ABC</span>
        <span class="monogram-customizer__style-label">Script</span>
      </button>
      <button type="button" class="monogram-customizer__style-btn" data-style="block">
        <span class="monogram-customizer__style-preview">ABC</span>
        <span class="monogram-customizer__style-label">Block</span>
      </button>
    </div>
  </div>

  <!-- Thread Color -->
  <div class="monogram-customizer__field">
    <label class="monogram-customizer__label">Thread Color</label>
    <div class="monogram-customizer__colors" id="color-picker">
      {% assign colors = "#FFFFFF,White|#000000,Black|#96A1A8,Grey|#A67843,Brown|#FFCC00,Gold|#E8D075,Cream|#CC3333,Red|#CC6699,Pink|#800020,Maroon|#FF6633,Orange|#3399FF,Royal Blue|#003366,Navy|#336633,Forest Green|#99CCCC,Light Blue|#800080,Purple" | split: "|" %}
      {% for color_pair in colors %}
        {% assign parts = color_pair | split: "," %}
        {% assign hex = parts[0] %}
        {% assign name = parts[1] %}
        <div
          class="monogram-customizer__color-swatch{% if hex == '#000000' %} active{% endif %}"
          data-color="{{ hex }}"
          data-name="{{ name }}"
          style="background-color: {{ hex }};"
          title="{{ name }}"
          role="button"
          tabindex="0"
        ></div>
      {% endfor %}
    </div>
    <div class="monogram-customizer__color-name" id="color-name">Black</div>
  </div>

  <!-- Loading indicator shown during preview generation -->
  <div class="monogram-customizer__loading" id="monogram-loading">
    <div class="monogram-customizer__spinner"></div>
    <span>Generating your monogram preview...</span>
  </div>

  <!-- Hidden inputs for line item properties -->
  <!-- Underscore-prefixed properties are hidden from customer but visible in admin/webhooks -->
  <input type="hidden" name="properties[_monogram_text]" id="prop-monogram-text" value="">
  <input type="hidden" name="properties[_monogram_style]" id="prop-monogram-style" value="script">
  <input type="hidden" name="properties[_thread_color]" id="prop-thread-color" value="#000000">
  <!-- Visible property: Shopify renders image URLs as thumbnails in cart/checkout/order -->
  <input type="hidden" name="properties[Monogram Preview]" id="prop-preview-image" value="">
</div>

<script>
  (function() {
    const textInput = document.getElementById('monogram-text');
    const charCount = document.getElementById('char-count');
    const errorEl = document.getElementById('monogram-error');
    const colorPicker = document.getElementById('color-picker');
    const colorNameEl = document.getElementById('color-name');
    const loadingEl = document.getElementById('monogram-loading');

    // Hidden properties
    const propText = document.getElementById('prop-monogram-text');
    const propStyle = document.getElementById('prop-monogram-style');
    const propColor = document.getElementById('prop-thread-color');
    const propPreviewImage = document.getElementById('prop-preview-image');

    let currentStyle = 'script';
    let currentColor = '#000000';
    let currentText = '';
    let overlayCanvas = null;
    let overlayCtx = null;
    let productImageEl = null;
    let isGeneratingPreview = false;

    // Find the product image and attach overlay canvas
    function initOverlay() {
      const selectors = [
        '.product__media img',
        '.product-media-container img',
        '.product__media-item img',
        '.product-featured-media img',
        '.product__main-photos img',
        '.product-single__photo img',
        '.product__photo img',
        'media-gallery img',
        '.product--media img',
        '[data-product-media-type="image"] img',
        '.product-image-container img',
        '.product__media-wrapper img',
        '.product__media-list img:first-of-type',
        'product-info media-gallery img',
        '.media-gallery img'
      ];

      for (const sel of selectors) {
        const img = document.querySelector(sel);
        if (img && img.naturalWidth > 100) {
          productImageEl = img;
          break;
        }
      }

      // Fallback: find the largest product image on the page
      if (!productImageEl) {
        const allImgs = document.querySelectorAll('img');
        let largest = null;
        let largestArea = 0;
        allImgs.forEach(img => {
          const area = img.offsetWidth * img.offsetHeight;
          if (area > largestArea && img.offsetWidth > 200) {
            largest = img;
            largestArea = area;
          }
        });
        productImageEl = largest;
      }

      if (!productImageEl) {
        console.warn('Monogram Customizer: Could not find product image for overlay');
        return;
      }

      // Make the image's parent position:relative so we can overlay
      const parent = productImageEl.parentElement;
      const parentPos = window.getComputedStyle(parent).position;
      if (parentPos === 'static') {
        parent.style.position = 'relative';
      }

      // Create overlay canvas
      overlayCanvas = document.createElement('canvas');
      overlayCanvas.className = 'monogram-overlay-canvas';
      parent.appendChild(overlayCanvas);
      overlayCtx = overlayCanvas.getContext('2d');

      positionOverlay();
      window.addEventListener('resize', positionOverlay);

      const observer = new MutationObserver(() => {
        setTimeout(positionOverlay, 100);
      });
      observer.observe(parent, { childList: true, subtree: true, attributes: true });
    }

    function positionOverlay() {
      if (!overlayCanvas || !productImageEl) return;

      const rect = productImageEl.getBoundingClientRect();
      const parentRect = productImageEl.parentElement.getBoundingClientRect();

      overlayCanvas.width = rect.width;
      overlayCanvas.height = rect.height;
      overlayCanvas.style.left = (rect.left - parentRect.left) + 'px';
      overlayCanvas.style.top = (rect.top - parentRect.top) + 'px';
      overlayCanvas.style.width = rect.width + 'px';
      overlayCanvas.style.height = rect.height + 'px';

      renderPreview();
    }

    // Style buttons
    document.querySelectorAll('.monogram-customizer__style-btn').forEach(btn => {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.monogram-customizer__style-btn').forEach(b => b.classList.remove('active'));
        this.classList.add('active');
        currentStyle = this.dataset.style;
        propStyle.value = currentStyle;
        renderPreview();
      });
    });

    // Color swatches
    colorPicker.addEventListener('click', function(e) {
      const swatch = e.target.closest('.monogram-customizer__color-swatch');
      if (!swatch) return;
      document.querySelectorAll('.monogram-customizer__color-swatch').forEach(s => s.classList.remove('active'));
      swatch.classList.add('active');
      currentColor = swatch.dataset.color;
      colorNameEl.textContent = swatch.dataset.name;
      propColor.value = currentColor;
      renderPreview();
    });

    // Text input
    textInput.addEventListener('input', function() {
      let val = this.value.replace(/[^a-zA-Z]/g, '').toUpperCase().slice(0, 3);
      this.value = val;
      currentText = val;
      charCount.textContent = val.length;
      propText.value = val;

      if (val.length === 0) {
        errorEl.classList.add('visible');
      } else {
        errorEl.classList.remove('visible');
      }

      renderPreview();
    });

    /**
     * Call the server-side preview API via app proxy to generate a permanent
     * preview image URL. Returns the URL string.
     */
    async function generatePreviewUrl() {
      const encodedColor = encodeURIComponent(currentColor);
      const apiUrl = '/apps/api/preview?text=' + encodeURIComponent(currentText)
        + '&style=' + encodeURIComponent(currentStyle)
        + '&color=' + encodedColor
        + '&format=json';

      try {
        const resp = await fetch(apiUrl, { credentials: 'same-origin' });
        if (!resp.ok) throw new Error('Preview API returned ' + resp.status);
        const data = await resp.json();
        return data.url || '';
      } catch (err) {
        console.error('Monogram preview API error:', err);
        // Fallback: generate a data URL from the overlay canvas
        return generateCanvasDataUrl();
      }
    }

    /**
     * Fallback: generate a data URL from a small offscreen canvas.
     */
    function generateCanvasDataUrl() {
      const size = 400;
      const c = document.createElement('canvas');
      c.width = size;
      c.height = size;
      const cx = c.getContext('2d');

      // Light background
      cx.fillStyle = '#f5f5f5';
      cx.fillRect(0, 0, size, size);

      // Simple hat silhouette
      cx.fillStyle = '#e8e8e8';
      cx.beginPath();
      cx.moveTo(size * 0.15, size * 0.55);
      cx.quadraticCurveTo(size * 0.15, size * 0.12, size * 0.5, size * 0.10);
      cx.quadraticCurveTo(size * 0.85, size * 0.12, size * 0.85, size * 0.55);
      cx.lineTo(size * 0.15, size * 0.55);
      cx.fill();

      cx.fillStyle = '#ddd';
      cx.beginPath();
      cx.moveTo(size * 0.05, size * 0.58);
      cx.quadraticCurveTo(size * 0.5, size * 0.50, size * 0.95, size * 0.58);
      cx.quadraticCurveTo(size * 0.5, size * 0.68, size * 0.05, size * 0.58);
      cx.fill();

      // Draw text
      const centerX = size * 0.50;
      const centerY = size * 0.38;
      const baseSize = size * 0.12;

      cx.fillStyle = currentColor;
      cx.textAlign = 'center';
      cx.textBaseline = 'middle';

      if (currentStyle === 'script') {
        cx.font = baseSize + 'px "Great Vibes", cursive';
        cx.fillText(currentText, centerX, centerY);
      } else {
        if (currentText.length === 3) {
          cx.font = 'bold ' + (baseSize * 1.3) + 'px "Montserrat", sans-serif';
          cx.fillText(currentText[1], centerX, centerY);
          cx.font = 'bold ' + (baseSize * 0.8) + 'px "Montserrat", sans-serif';
          cx.fillText(currentText[0], centerX - baseSize * 1.2, centerY);
          cx.fillText(currentText[2], centerX + baseSize * 1.2, centerY);
        } else {
          cx.font = 'bold ' + baseSize + 'px "Montserrat", sans-serif';
          cx.fillText(currentText, centerX, centerY);
        }
      }

      return c.toDataURL('image/png');
    }

    // Move hidden inputs into the product form and intercept add-to-cart
    const form = document.querySelector('form[action*="/cart/add"]') || document.querySelector('product-form form');
    if (form) {
      const customizer = document.getElementById('monogram-customizer');
      const hiddenInputs = customizer.querySelectorAll('input[type="hidden"]');
      hiddenInputs.forEach(input => {
        form.appendChild(input);
      });

      // Intercept form submission to generate preview first
      form.addEventListener('submit', async function(e) {
        // Only intercept if there's monogram text
        if (currentText.length === 0) {
          e.preventDefault();
          errorEl.classList.add('visible');
          textInput.focus();
          return;
        }

        // If already generating, prevent double-submit
        if (isGeneratingPreview) {
          e.preventDefault();
          return;
        }

        // Prevent the default submit, generate preview, then re-submit
        e.preventDefault();
        isGeneratingPreview = true;
        loadingEl.classList.add('visible');

        try {
          const previewUrl = await generatePreviewUrl();
          propPreviewImage.value = previewUrl;
          console.log('Monogram preview URL:', previewUrl);
        } catch (err) {
          console.error('Failed to generate preview:', err);
          // Use fallback data URL
          propPreviewImage.value = generateCanvasDataUrl();
        }

        isGeneratingPreview = false;
        loadingEl.classList.remove('visible');

        // Now submit the form for real
        // Use requestSubmit if available (triggers native submit without re-triggering our listener)
        // We need to temporarily remove our listener to avoid infinite loop
        form.removeEventListener('submit', arguments.callee);

        // Use the Shopify Cart AJAX API directly to add the item with properties
        const formData = new FormData(form);
        const variantId = formData.get('id') || form.querySelector('[name="id"]')?.value;

        if (variantId) {
          const properties = {};
          properties['_monogram_text'] = propText.value;
          properties['_monogram_style'] = propStyle.value;
          properties['_thread_color'] = propColor.value;
          if (propPreviewImage.value) {
            properties['Monogram Preview'] = propPreviewImage.value;
          }

          try {
            const resp = await fetch('/cart/add.js', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                id: parseInt(variantId),
                quantity: parseInt(formData.get('quantity') || '1'),
                properties: properties
              })
            });

            if (resp.ok) {
              // Trigger cart drawer open or redirect to cart
              // Dispatch a custom event that Dawn theme listens for
              document.dispatchEvent(new CustomEvent('cart:refresh'));

              // Try to open the cart drawer (Dawn theme)
              const cartDrawer = document.querySelector('cart-notification') || document.querySelector('cart-drawer');
              if (cartDrawer && typeof cartDrawer.open === 'function') {
                cartDrawer.open();
              }

              // Refresh the page cart state
              window.location.href = '/cart';
            } else {
              console.error('Cart add failed:', await resp.text());
              // Fallback: submit the form normally
              form.submit();
            }
          } catch (err) {
            console.error('Cart AJAX error:', err);
            form.submit();
          }
        } else {
          form.submit();
        }
      });
    }

    // Canvas preview rendering — draw on the overlay canvas on top of the product image
    function renderPreview() {
      if (!overlayCanvas || !overlayCtx) return;

      const w = overlayCanvas.width;
      const h = overlayCanvas.height;

      overlayCtx.clearRect(0, 0, w, h);

      if (!currentText) return;

      // Position the monogram on the front of the hat
      const centerX = w * 0.50;
      const centerY = h * 0.42;

      // Scale font size relative to image size
      const baseSize = Math.min(w, h) * 0.12;

      overlayCtx.fillStyle = currentColor;
      overlayCtx.textAlign = 'center';
      overlayCtx.textBaseline = 'middle';

      // Subtle text shadow for visibility
      overlayCtx.shadowColor = 'rgba(0,0,0,0.15)';
      overlayCtx.shadowBlur = 2;
      overlayCtx.shadowOffsetX = 1;
      overlayCtx.shadowOffsetY = 1;

      if (currentStyle === 'script') {
        overlayCtx.font = baseSize + 'px "Great Vibes", cursive';
        overlayCtx.fillText(currentText, centerX, centerY);
      } else {
        if (currentText.length === 3) {
          overlayCtx.font = 'bold ' + (baseSize * 1.3) + 'px "Montserrat", sans-serif';
          overlayCtx.fillText(currentText[1], centerX, centerY);

          const sideSize = baseSize * 0.8;
          const spacing = baseSize * 1.2;
          overlayCtx.font = 'bold ' + sideSize + 'px "Montserrat", sans-serif';
          overlayCtx.fillText(currentText[0], centerX - spacing, centerY);
          overlayCtx.fillText(currentText[2], centerX + spacing, centerY);
        } else {
          overlayCtx.font = 'bold ' + baseSize + 'px "Montserrat", sans-serif';
          overlayCtx.fillText(currentText, centerX, centerY);
        }
      }

      // Reset shadow
      overlayCtx.shadowColor = 'transparent';
      overlayCtx.shadowBlur = 0;
      overlayCtx.shadowOffsetX = 0;
      overlayCtx.shadowOffsetY = 0;
    }

    // Wait for fonts and images to load, then init overlay
    function waitAndInit() {
      if (document.fonts && document.fonts.ready) {
        document.fonts.ready.then(() => {
          setTimeout(initOverlay, 500);
        });
      } else {
        setTimeout(initOverlay, 1000);
      }
    }

    if (document.readyState === 'complete') {
      waitAndInit();
    } else {
      window.addEventListener('load', waitAndInit);
    }

    document.addEventListener('shopify:section:load', waitAndInit);
  })();
</script>

{% schema %}
{
  "name": "Monogram Customizer",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Personalize Your Hat"
    }
  ]
}
{% endschema %}
