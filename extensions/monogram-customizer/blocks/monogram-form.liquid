{% comment %}
  Monogram Customizer Block
  Renders a personalization form on the product page with:
  - Text input (1-3 characters)
  - Font style selector (script / block)
  - Thread color picker (Printful's 15 embroidery colors)
  - Live preview overlaid on the product image
  
  Strategy: Instead of intercepting the form submit (which Dawn's web component
  prevents), we monkey-patch window.fetch to intercept any POST to /cart/add.js
  and inject our monogram properties into the request body. This works regardless
  of how the theme handles add-to-cart (form submit, AJAX, web component, etc.)
{% endcomment %}

<style>
  .monogram-customizer {
    margin: 16px 0;
    padding: 20px;
    border: 1px solid #e5e5e5;
    border-radius: 8px;
    background: #fafafa;
    font-family: inherit;
  }

  .monogram-customizer__title {
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 16px;
    color: #1a1a1a;
  }

  .monogram-customizer__field {
    margin-bottom: 16px;
  }

  .monogram-customizer__label {
    display: block;
    font-size: 13px;
    font-weight: 500;
    margin-bottom: 6px;
    color: #333;
  }

  .monogram-customizer__input {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid #ccc;
    border-radius: 6px;
    font-size: 18px;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 4px;
    box-sizing: border-box;
  }

  .monogram-customizer__input:focus {
    outline: none;
    border-color: #333;
  }

  .monogram-customizer__char-count {
    font-size: 11px;
    color: #999;
    text-align: right;
    margin-top: 4px;
  }

  .monogram-customizer__styles {
    display: flex;
    gap: 8px;
  }

  .monogram-customizer__style-btn {
    flex: 1;
    padding: 10px;
    border: 2px solid #ddd;
    border-radius: 6px;
    background: white;
    cursor: pointer;
    text-align: center;
    transition: all 0.2s;
  }

  .monogram-customizer__style-btn:hover {
    border-color: #999;
  }

  .monogram-customizer__style-btn.active {
    border-color: #333;
    background: #f5f5f5;
  }

  .monogram-customizer__style-label {
    display: block;
    font-size: 12px;
    font-weight: 500;
    margin-top: 4px;
  }

  .monogram-customizer__style-preview {
    font-size: 20px;
    line-height: 1.2;
  }

  .monogram-customizer__style-btn[data-style="script"] .monogram-customizer__style-preview {
    font-family: 'Great Vibes', cursive, serif;
    font-style: italic;
  }

  .monogram-customizer__style-btn[data-style="block"] .monogram-customizer__style-preview {
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    letter-spacing: 3px;
  }

  .monogram-customizer__colors {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .monogram-customizer__color-swatch {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 2px solid transparent;
    cursor: pointer;
    transition: all 0.2s;
    position: relative;
  }

  .monogram-customizer__color-swatch:hover {
    transform: scale(1.15);
  }

  .monogram-customizer__color-swatch.active {
    border-color: #333;
    box-shadow: 0 0 0 2px white, 0 0 0 4px #333;
  }

  .monogram-customizer__color-swatch[data-color="#FFFFFF"] {
    border-color: #ddd;
  }

  .monogram-customizer__color-name {
    font-size: 11px;
    color: #666;
    margin-top: 6px;
  }

  .monogram-customizer__error {
    color: #cc0000;
    font-size: 12px;
    margin-top: 4px;
    display: none;
  }

  .monogram-customizer__error.visible {
    display: block;
  }

  /* Overlay canvas on product image */
  .monogram-overlay-canvas {
    position: absolute;
    pointer-events: none;
    z-index: 10;
  }
</style>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Montserrat:wght@700&display=swap" rel="stylesheet">

<div class="monogram-customizer" id="monogram-customizer">
  <div class="monogram-customizer__title">{{ block.settings.title }}</div>

  <!-- Text Input -->
  <div class="monogram-customizer__field">
    <label class="monogram-customizer__label" for="monogram-text">Monogram Text (1-3 letters)</label>
    <input
      type="text"
      id="monogram-text"
      class="monogram-customizer__input"
      maxlength="3"
      placeholder="ABC"
      autocomplete="off"
    >
    <div class="monogram-customizer__char-count"><span id="char-count">0</span>/3</div>
    <div class="monogram-customizer__error" id="monogram-error">Please enter 1-3 letters for your monogram</div>
  </div>

  <!-- Font Style -->
  <div class="monogram-customizer__field">
    <label class="monogram-customizer__label">Font Style</label>
    <div class="monogram-customizer__styles">
      <button type="button" class="monogram-customizer__style-btn active" data-style="script">
        <span class="monogram-customizer__style-preview">ABC</span>
        <span class="monogram-customizer__style-label">Script</span>
      </button>
      <button type="button" class="monogram-customizer__style-btn" data-style="block">
        <span class="monogram-customizer__style-preview">ABC</span>
        <span class="monogram-customizer__style-label">Block</span>
      </button>
    </div>
  </div>

  <!-- Thread Color -->
  <div class="monogram-customizer__field">
    <label class="monogram-customizer__label">Thread Color</label>
    <div class="monogram-customizer__colors" id="color-picker">
      {% assign colors = "#FFFFFF,White|#000000,Black|#96A1A8,Grey|#A67843,Brown|#FFCC00,Gold|#E8D075,Cream|#CC3333,Red|#CC6699,Pink|#800020,Maroon|#FF6633,Orange|#3399FF,Royal Blue|#003366,Navy|#336633,Forest Green|#99CCCC,Light Blue|#800080,Purple" | split: "|" %}
      {% for color_pair in colors %}
        {% assign parts = color_pair | split: "," %}
        {% assign hex = parts[0] %}
        {% assign name = parts[1] %}
        <div
          class="monogram-customizer__color-swatch{% if hex == '#000000' %} active{% endif %}"
          data-color="{{ hex }}"
          data-name="{{ name }}"
          style="background-color: {{ hex }};"
          title="{{ name }}"
          role="button"
          tabindex="0"
        ></div>
      {% endfor %}
    </div>
    <div class="monogram-customizer__color-name" id="color-name">Black</div>
  </div>
</div>

<script>
  (function() {
    'use strict';

    const textInput = document.getElementById('monogram-text');
    const charCount = document.getElementById('char-count');
    const errorEl = document.getElementById('monogram-error');
    const colorPicker = document.getElementById('color-picker');
    const colorNameEl = document.getElementById('color-name');

    let currentStyle = 'script';
    let currentColor = '#000000';
    let currentText = '';
    let overlayCanvas = null;
    let overlayCtx = null;
    let productImageEl = null;

    // ─── Build the app proxy preview image URL ───
    function buildPreviewImageUrl() {
      if (!currentText) return '';
      return '/apps/api/preview?text=' + encodeURIComponent(currentText)
        + '&style=' + encodeURIComponent(currentStyle)
        + '&color=' + encodeURIComponent(currentColor)
        + '&format=image';
    }

    // ─── MONKEY-PATCH window.fetch ───
    // Dawn theme's product-form web component uses fetch() to POST to /cart/add.js.
    // We intercept that call and inject our monogram properties into the request body.
    // IMPORTANT: We must preserve ALL original fields (especially 'sections' which Dawn
    // uses to render the cart drawer). If we drop 'sections', the cart drawer crashes.
    const originalFetch = window.fetch;
    window.fetch = function(url, options) {
      // Check if this is a cart/add.js call
      var urlStr = (typeof url === 'string') ? url : (url && url.url ? url.url : '');
      if (urlStr.indexOf('/cart/add') !== -1 && options && options.method && options.method.toUpperCase() === 'POST') {
        // Only inject if there's monogram text
        if (currentText && currentText.length > 0) {
          try {
            var body = options.body;
            var isFormData = body instanceof FormData;

            if (isFormData) {
              // Dawn sends FormData. We inject our properties as FormData entries.
              // This preserves the 'sections' and 'sections_url' fields that Dawn needs.
              body.append('properties[_monogram_text]', currentText);
              body.append('properties[_monogram_style]', currentStyle);
              body.append('properties[_thread_color]', currentColor);
              body.append('properties[Monogram Preview]', buildPreviewImageUrl());

              console.log('[Monogram] Injected properties into FormData cart/add.js');
              // options.body is already the modified FormData reference
            } else if (typeof body === 'string') {
              // JSON body — parse, inject, re-stringify
              var parsed = JSON.parse(body);
              if (!parsed.properties) parsed.properties = {};
              parsed.properties['_monogram_text'] = currentText;
              parsed.properties['_monogram_style'] = currentStyle;
              parsed.properties['_thread_color'] = currentColor;
              parsed.properties['Monogram Preview'] = buildPreviewImageUrl();

              console.log('[Monogram] Injected properties into JSON cart/add.js:', parsed.properties);
              options.body = JSON.stringify(parsed);
            }
          } catch (e) {
            console.warn('[Monogram] Could not inject properties into fetch body:', e);
          }
        }
      }
      return originalFetch.apply(this, arguments);
    };

    // ─── Also patch XMLHttpRequest for older themes ───
    var origXHROpen = XMLHttpRequest.prototype.open;
    var origXHRSend = XMLHttpRequest.prototype.send;

    XMLHttpRequest.prototype.open = function(method, url) {
      this._monogramUrl = url;
      this._monogramMethod = method;
      return origXHROpen.apply(this, arguments);
    };

    XMLHttpRequest.prototype.send = function(body) {
      if (this._monogramUrl && this._monogramUrl.indexOf('/cart/add') !== -1
          && this._monogramMethod && this._monogramMethod.toUpperCase() === 'POST'
          && currentText && currentText.length > 0) {
        try {
          var parsed = null;
          if (typeof body === 'string') {
            parsed = JSON.parse(body);
          }
          if (parsed) {
            if (!parsed.properties) parsed.properties = {};
            parsed.properties['_monogram_text'] = currentText;
            parsed.properties['_monogram_style'] = currentStyle;
            parsed.properties['_thread_color'] = currentColor;
            parsed.properties['Monogram Preview'] = buildPreviewImageUrl();
            console.log('[Monogram] Injected properties into XHR cart/add:', parsed.properties);
            this.setRequestHeader('Content-Type', 'application/json');
            return origXHRSend.call(this, JSON.stringify(parsed));
          }
        } catch (e) {
          console.warn('[Monogram] Could not inject properties into XHR body:', e);
        }
      }
      return origXHRSend.apply(this, arguments);
    };

    // ─── Find the product image and attach overlay canvas ───
    function initOverlay() {
      var selectors = [
        '.product__media img',
        '.product-media-container img',
        '.product__media-item img',
        '.product-featured-media img',
        '.product__main-photos img',
        '.product-single__photo img',
        '.product__photo img',
        'media-gallery img',
        '.product--media img',
        '[data-product-media-type="image"] img',
        '.product-image-container img',
        '.product__media-wrapper img',
        '.product__media-list img:first-of-type',
        'product-info media-gallery img',
        '.media-gallery img'
      ];

      for (var i = 0; i < selectors.length; i++) {
        var img = document.querySelector(selectors[i]);
        if (img && img.naturalWidth > 100) {
          productImageEl = img;
          break;
        }
      }

      // Fallback: find the largest product image on the page
      if (!productImageEl) {
        var allImgs = document.querySelectorAll('img');
        var largest = null;
        var largestArea = 0;
        allImgs.forEach(function(img) {
          var area = img.offsetWidth * img.offsetHeight;
          if (area > largestArea && img.offsetWidth > 200) {
            largest = img;
            largestArea = area;
          }
        });
        productImageEl = largest;
      }

      if (!productImageEl) {
        console.warn('[Monogram] Could not find product image for overlay');
        return;
      }

      // Make the image's parent position:relative so we can overlay
      var parent = productImageEl.parentElement;
      var parentPos = window.getComputedStyle(parent).position;
      if (parentPos === 'static') {
        parent.style.position = 'relative';
      }

      // Create overlay canvas
      overlayCanvas = document.createElement('canvas');
      overlayCanvas.className = 'monogram-overlay-canvas';
      parent.appendChild(overlayCanvas);
      overlayCtx = overlayCanvas.getContext('2d');

      positionOverlay();
      window.addEventListener('resize', positionOverlay);

      var observer = new MutationObserver(function() {
        setTimeout(positionOverlay, 100);
      });
      observer.observe(parent, { childList: true, subtree: true, attributes: true });
    }

    function positionOverlay() {
      if (!overlayCanvas || !productImageEl) return;

      var rect = productImageEl.getBoundingClientRect();
      var parentRect = productImageEl.parentElement.getBoundingClientRect();

      overlayCanvas.width = rect.width;
      overlayCanvas.height = rect.height;
      overlayCanvas.style.left = (rect.left - parentRect.left) + 'px';
      overlayCanvas.style.top = (rect.top - parentRect.top) + 'px';
      overlayCanvas.style.width = rect.width + 'px';
      overlayCanvas.style.height = rect.height + 'px';

      renderPreview();
    }

    // ─── Style buttons ───
    document.querySelectorAll('.monogram-customizer__style-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.monogram-customizer__style-btn').forEach(function(b) { b.classList.remove('active'); });
        this.classList.add('active');
        currentStyle = this.dataset.style;
        renderPreview();
      });
    });

    // ─── Color swatches ───
    colorPicker.addEventListener('click', function(e) {
      var swatch = e.target.closest('.monogram-customizer__color-swatch');
      if (!swatch) return;
      document.querySelectorAll('.monogram-customizer__color-swatch').forEach(function(s) { s.classList.remove('active'); });
      swatch.classList.add('active');
      currentColor = swatch.dataset.color;
      colorNameEl.textContent = swatch.dataset.name;
      renderPreview();
    });

    // ─── Text input ───
    textInput.addEventListener('input', function() {
      var val = this.value.replace(/[^a-zA-Z]/g, '').toUpperCase().slice(0, 3);
      this.value = val;
      currentText = val;
      charCount.textContent = val.length;

      if (val.length === 0) {
        errorEl.classList.add('visible');
      } else {
        errorEl.classList.remove('visible');
      }

      renderPreview();
    });

    // ─── Canvas preview rendering ───
    function renderPreview() {
      if (!overlayCanvas || !overlayCtx) return;

      var w = overlayCanvas.width;
      var h = overlayCanvas.height;

      overlayCtx.clearRect(0, 0, w, h);

      if (!currentText) return;

      // Position the monogram on the front of the hat
      var centerX = w * 0.50;
      var centerY = h * 0.42;

      // Scale font size relative to image size
      var baseSize = Math.min(w, h) * 0.12;

      overlayCtx.fillStyle = currentColor;
      overlayCtx.textAlign = 'center';
      overlayCtx.textBaseline = 'middle';

      // Subtle text shadow for visibility
      overlayCtx.shadowColor = 'rgba(0,0,0,0.15)';
      overlayCtx.shadowBlur = 2;
      overlayCtx.shadowOffsetX = 1;
      overlayCtx.shadowOffsetY = 1;

      if (currentStyle === 'script') {
        overlayCtx.font = baseSize + 'px "Great Vibes", cursive';
        overlayCtx.fillText(currentText, centerX, centerY);
      } else {
        if (currentText.length === 3) {
          overlayCtx.font = 'bold ' + (baseSize * 1.3) + 'px "Montserrat", sans-serif';
          overlayCtx.fillText(currentText[1], centerX, centerY);

          var sideSize = baseSize * 0.8;
          var spacing = baseSize * 1.2;
          overlayCtx.font = 'bold ' + sideSize + 'px "Montserrat", sans-serif';
          overlayCtx.fillText(currentText[0], centerX - spacing, centerY);
          overlayCtx.fillText(currentText[2], centerX + spacing, centerY);
        } else {
          overlayCtx.font = 'bold ' + baseSize + 'px "Montserrat", sans-serif';
          overlayCtx.fillText(currentText, centerX, centerY);
        }
      }

      // Reset shadow
      overlayCtx.shadowColor = 'transparent';
      overlayCtx.shadowBlur = 0;
      overlayCtx.shadowOffsetX = 0;
      overlayCtx.shadowOffsetY = 0;
    }

    // ─── Init ───
    function initWhenReady() {
      if (document.fonts && document.fonts.ready) {
        document.fonts.ready.then(function() {
          setTimeout(initOverlay, 500);
        });
      } else {
        setTimeout(initOverlay, 1000);
      }
    }

    if (document.readyState === 'complete') {
      initWhenReady();
    } else {
      window.addEventListener('load', initWhenReady);
    }

    document.addEventListener('shopify:section:load', initWhenReady);
  })();
</script>

{% schema %}
{
  "name": "Monogram Customizer",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Personalize Your Hat"
    }
  ]
}
{% endschema %}
