{% comment %}
  Cart Preview Block
  Enhances the cart drawer and cart page by swapping product thumbnails
  with the monogram preview image for personalized items.
  Reads the "Monogram Preview" line item property via the Cart AJAX API.
  
  The preview URL is an app proxy path like:
    /apps/proxy/preview?text=ABC&style=script&color=%23000000&format=image
  
  Shows a spinning loader while the preview image loads, then swaps it in.
  
  Note: Shopify checkout and order confirmation automatically render
  image URLs stored in visible line item properties, so this block
  is primarily needed for the storefront cart drawer and cart page.
{% endcomment %}

<style>
  .monogram-cart-spinner {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 24px;
    height: 24px;
    border: 3px solid #e5e5e5;
    border-top-color: #333;
    border-radius: 50%;
    animation: monogram-spin 0.7s linear infinite;
    z-index: 5;
    pointer-events: none;
  }
  @keyframes monogram-spin {
    to { transform: translate(-50%, -50%) rotate(360deg); }
  }
  .monogram-cart-loading {
    position: relative;
  }
  .monogram-cart-loading img {
    opacity: 0.3;
    transition: opacity 0.3s ease;
  }
  .monogram-cart-loaded img {
    opacity: 1;
  }
</style>

<script>
  (function() {
    'use strict';

    let debounceTimer = null;
    const preloadCache = {};

    function preloadImage(url) {
      return new Promise(function(resolve, reject) {
        if (preloadCache[url]) {
          resolve(url);
          return;
        }
        var img = new Image();
        img.onload = function() {
          preloadCache[url] = true;
          resolve(url);
        };
        img.onerror = reject;
        img.src = url;
      });
    }

    function replaceCartThumbnails() {
      fetch('/cart.js', { credentials: 'same-origin' })
        .then(function(r) { return r.json(); })
        .then(function(cart) {
          if (!cart || !cart.items) return;

          cart.items.forEach(function(item, index) {
            // Check for our visible preview image property
            var previewUrl = item.properties && (item.properties['_preview_image'] || item.properties['Monogram Preview']);
            if (!previewUrl) return;

            // Find all cart item containers in the DOM
            var cartItemSelectors = [
              'cart-drawer-items .cart-item',
              '#CartDrawer .cart-item',
              '#cart-drawer .cart-item',
              'cart-notification .cart-notification-product',
              'cart-items .cart-item',
              'cart-items tr.cart-item',
              'table.cart-items tbody tr',
              '.cart-item',
              '.cart__item',
              '.mini-cart__item',
              '[data-cart-item]',
              '.cart-items__item',
              '.cart-drawer__item',
              '.cart__row'
            ];

            var cartItems = [];
            for (var i = 0; i < cartItemSelectors.length; i++) {
              cartItems = document.querySelectorAll(cartItemSelectors[i]);
              if (cartItems.length > 0) break;
            }

            if (cartItems.length === 0) return;

            var targetItem = cartItems[index];
            if (!targetItem) return;

            var imgs = targetItem.querySelectorAll('img');
            if (imgs.length === 0) return;

            imgs.forEach(function(img) {
              if (img.dataset.monogramReplaced === 'true') return;

              var fullUrl = previewUrl;
              if (previewUrl.startsWith('/')) {
                fullUrl = window.location.origin + previewUrl;
              }
              // Request smaller thumbnail for cart
              if (fullUrl.indexOf('size=') === -1) {
                fullUrl += (fullUrl.indexOf('?') !== -1 ? '&' : '?') + 'size=thumb';
              }

              // Mark as being replaced so we don't double-process
              img.dataset.monogramReplaced = 'true';
              img.dataset.originalSrc = img.src;

              // Add spinner overlay
              var wrapper = img.parentElement;
              if (wrapper) {
                wrapper.classList.add('monogram-cart-loading');
                wrapper.style.position = wrapper.style.position || 'relative';
                
                // Add spinner if not already there
                if (!wrapper.querySelector('.monogram-cart-spinner')) {
                  var spinner = document.createElement('div');
                  spinner.className = 'monogram-cart-spinner';
                  wrapper.appendChild(spinner);
                }
              }

              // Preload the image, then swap
              preloadImage(fullUrl).then(function() {
                img.src = fullUrl;
                img.srcset = '';
                if (img.dataset.src) img.dataset.src = fullUrl;
                if (img.dataset.srcset) img.dataset.srcset = '';
                img.style.objectFit = 'contain';

                // Remove spinner and restore opacity
                if (wrapper) {
                  wrapper.classList.remove('monogram-cart-loading');
                  wrapper.classList.add('monogram-cart-loaded');
                  var spinner = wrapper.querySelector('.monogram-cart-spinner');
                  if (spinner) spinner.remove();
                }
              }).catch(function() {
                // On error, just swap directly (better than nothing)
                img.src = fullUrl;
                img.srcset = '';
                img.style.objectFit = 'contain';
                if (wrapper) {
                  wrapper.classList.remove('monogram-cart-loading');
                  var spinner = wrapper.querySelector('.monogram-cart-spinner');
                  if (spinner) spinner.remove();
                }
              });
            });
          });
        })
        .catch(function(err) {
          console.warn('Monogram cart preview: Could not fetch cart data', err);
        });
    }

    function debouncedReplace() {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(replaceCartThumbnails, 300);
    }

    // Run on page load
    if (document.readyState === 'complete' || document.readyState === 'interactive') {
      debouncedReplace();
    } else {
      document.addEventListener('DOMContentLoaded', debouncedReplace);
    }

    // Watch for DOM changes (cart drawer opening, AJAX cart updates)
    var observer = new MutationObserver(function(mutations) {
      var isCartRelated = mutations.some(function(m) {
        var target = m.target;
        if (!target || !target.closest) return true;
        return target.closest('[id*="cart" i], [class*="cart" i], cart-drawer, cart-notification, cart-drawer-items');
      });
      if (isCartRelated) {
        debouncedReplace();
      }
    });
    observer.observe(document.body, { childList: true, subtree: true });

    // Listen for Shopify and custom cart events
    document.addEventListener('shopify:section:load', debouncedReplace);
    document.addEventListener('cart:updated', debouncedReplace);
    document.addEventListener('cart:refresh', debouncedReplace);

    // Also run periodically for the first few seconds after page load
    var runCount = 0;
    var periodicCheck = setInterval(function() {
      debouncedReplace();
      runCount++;
      if (runCount >= 10) clearInterval(periodicCheck);
    }, 1000);
  })();
</script>

{% schema %}
{
  "name": "Monogram Cart Preview",
  "target": "body",
  "settings": []
}
{% endschema %}
