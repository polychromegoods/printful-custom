{% comment %}
  Cart Preview Block
  Automatically replaces product thumbnails in the cart with the monogram
  preview image for personalized items. Works on cart page and cart drawer.
  Reads line item properties via the Cart AJAX API.
{% endcomment %}

<style>
  .monogram-cart-thumb {
    object-fit: contain;
    border-radius: 4px;
  }
</style>

<script>
  (function() {
    'use strict';

    // Debounce to avoid rapid re-runs
    let debounceTimer = null;

    function replaceCartThumbnails() {
      fetch('/cart.js', { credentials: 'same-origin' })
        .then(r => r.json())
        .then(cart => {
          if (!cart || !cart.items) return;

          cart.items.forEach((item, index) => {
            // Check for our preview image property
            const previewUrl = item.properties && item.properties['_preview_image'];
            if (!previewUrl) return;

            // Build the full preview URL (it's a relative app proxy path)
            const fullUrl = previewUrl;

            // Find the cart item row in the DOM
            // Dawn theme uses various selectors; try multiple approaches
            const cartItemSelectors = [
              // Dawn cart page
              'cart-items .cart-item',
              'cart-items tr',
              '.cart-item',
              '.cart__item',
              // Cart drawer
              'cart-drawer-items .cart-item',
              '.cart-drawer__item',
              '.mini-cart__item',
              // Generic
              '[data-cart-item]',
              '.cart-items__item',
              'table.cart-items tbody tr'
            ];

            let cartItems = [];
            for (const sel of cartItemSelectors) {
              cartItems = document.querySelectorAll(sel);
              if (cartItems.length > 0) break;
            }

            if (cartItems.length === 0) return;

            // Match by product title + variant or by index
            const targetItem = cartItems[index];
            if (!targetItem) return;

            // Find the image inside this cart item
            const img = targetItem.querySelector('img');
            if (!img) return;

            // Only replace if not already replaced
            if (img.dataset.monogramReplaced === 'true') return;

            // Store original src for potential restoration
            img.dataset.originalSrc = img.src;
            img.dataset.monogramReplaced = 'true';

            // Replace with our preview image
            img.src = fullUrl;
            img.srcset = ''; // Clear srcset to prevent override
            img.classList.add('monogram-cart-thumb');

            // Also update any lazy-load attributes
            if (img.dataset.src) img.dataset.src = fullUrl;
            if (img.dataset.srcset) img.dataset.srcset = '';
          });
        })
        .catch(err => {
          console.warn('Monogram cart preview: Could not fetch cart data', err);
        });
    }

    function debouncedReplace() {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(replaceCartThumbnails, 300);
    }

    // Run on page load
    if (document.readyState === 'complete' || document.readyState === 'interactive') {
      debouncedReplace();
    } else {
      document.addEventListener('DOMContentLoaded', debouncedReplace);
    }

    // Re-run when cart drawer opens or cart page updates
    // Watch for DOM changes (cart drawer opening, AJAX cart updates)
    const observer = new MutationObserver(debouncedReplace);
    observer.observe(document.body, {
      childList: true,
      subtree: true
    });

    // Also listen for Shopify section rendering events
    document.addEventListener('shopify:section:load', debouncedReplace);

    // Listen for cart update events (some themes dispatch these)
    document.addEventListener('cart:updated', debouncedReplace);
    document.addEventListener('cart:refresh', debouncedReplace);
  })();
</script>

{% schema %}
{
  "name": "Monogram Cart Preview",
  "target": "body",
  "templates": ["cart"],
  "settings": []
}
{% endschema %}
