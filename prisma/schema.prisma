// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// ─── Product Template ────────────────────────────────────────────────────────
// Links a Shopify product to a product base from the registry,
// with chosen technique and placement configuration.
model ProductTemplate {
  id                  String   @id @default(cuid())
  shop                String

  // Shopify product link
  shopifyProductId    String   // e.g. "gid://shopify/Product/123456"
  productTitle        String   // cached product title for display
  productHandle       String?  // cached product handle

  // Product base reference (slug from product-bases.ts registry)
  productBaseSlug     String   // e.g. "yupoong-6245cm" or "comfort-colors-1717"

  // Chosen technique for this product
  technique           String   // e.g. "embroidery", "dtg", "dtfilm"

  // Chosen placement key
  placementKey        String   // e.g. "embroidery_front", "front", "embroidery_chest_left"

  // Print area overlay position on mockup (% of image)
  // These override the defaults from the registry for fine-tuning
  printAreaX          Float    @default(25)
  printAreaY          Float    @default(15)
  printAreaWidth      Float    @default(50)
  printAreaHeight     Float    @default(35)

  // Which fonts are enabled for this template (JSON array of font keys)
  enabledFonts        String   @default("[\"script\",\"block\"]")

  // Which thread colors are enabled (JSON array of hex codes, empty = all)
  enabledThreadColors String   @default("[]")

  // Which product variant colors are enabled (JSON array of color names, empty = all)
  enabledVariantColors String  @default("[]")

  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  layers              TemplateLayer[]
  mockupImages        MockupImage[]

  @@unique([shop, shopifyProductId])
  @@index([shop])
  @@index([productBaseSlug])
}

// ─── Template Layer ──────────────────────────────────────────────────────────
// A customizable or fixed element within a product template.
// Layers are composited in sortOrder to create the final print file.
model TemplateLayer {
  id                  String   @id @default(cuid())
  templateId          String

  // Layer type: "text" | "image" | "fixed_image"
  layerType           String

  // Human-readable label shown to customer
  label               String   @default("Custom Text")

  // Whether the customer can edit this layer on the storefront
  customerEditable    Boolean  @default(true)

  // Position within the print area (% of print area dimensions)
  positionX           Float    @default(10)
  positionY           Float    @default(10)
  positionWidth       Float    @default(80)
  positionHeight      Float    @default(80)

  // Sort order for compositing (lower = behind)
  sortOrder           Int      @default(0)

  // ── Text layer options ──
  maxChars            Int?     @default(3)
  placeholder         String?  @default("ABC")
  // Enabled fonts for this layer (JSON array of font keys, empty = use template default)
  enabledFonts        String?
  // Default font key
  defaultFont         String?  @default("script")
  // Default text color hex
  defaultColor        String?  @default("#000000")

  // ── Image layer options ──
  acceptedFileTypes   String?  @default("[\"image/png\",\"image/jpeg\"]")
  maxFileSizeMb       Float?   @default(10)

  // ── Fixed image layer options ──
  fixedImageUrl       String?  // URL to the fixed/template image (e.g., a frame)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  template            ProductTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
}

// ─── Mockup Image ────────────────────────────────────────────────────────────
// A blank product photo for a specific color variant.
// Used as the base for the live preview overlay on the storefront.
model MockupImage {
  id                  String   @id @default(cuid())
  templateId          String

  // Which variant color this mockup represents
  variantColor        String   // e.g. "White", "Navy", "Black"
  variantColorHex     String?  // e.g. "#ffffff"
  shopifyVariantId    String?  // optional link to Shopify variant GID

  // The mockup image URL (Shopify Files CDN or external)
  imageUrl            String

  // Is this the default/fallback mockup?
  isDefault           Boolean  @default(false)

  sortOrder           Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  template            ProductTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, variantColor])
  @@index([templateId])
}

// ─── Personalization Order ───────────────────────────────────────────────────
// Tracks each personalized order from Shopify through to Printful fulfillment.
model PersonalizationOrder {
  id                String   @id @default(cuid())
  shop              String
  shopifyOrderId    String
  shopifyOrderName  String
  shopifyVariantId  String
  customerEmail     String?
  customerName      String?

  // Template reference
  templateId        String?

  // Product base reference
  productBaseSlug   String?
  technique         String?
  placementKey      String?

  // Personalization inputs (JSON blob for flexibility)
  // Contains: { layers: [{ key, type, value, font, color }] }
  personalizationData String  @default("{}")

  // Legacy fields (kept for backward compat)
  monogramText      String?
  monogramStyle     String?  @default("script")
  threadColor       String?  @default("#000000")

  // Fulfillment provider: "printful" | "printify"
  fulfillmentProvider String @default("printful")

  // Processing status: pending | generating | uploading | submitting | completed | failed
  status            String   @default("pending")
  errorMessage      String?

  // Print file (shared)
  printFileUrl      String?

  // Printful integration
  printfulFileId    String?
  printfulOrderId   String?
  printfulStatus    String?
  printfulVariantId Int?

  // Printify integration
  printifyImageId   String?
  printifyOrderId   String?
  printifyStatus    String?
  printifyVariantId Int?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([shop])
  @@index([shopifyOrderId])
  @@index([status])
  @@index([templateId])
}

// ─── Product Base Definition (DB-managed) ──────────────────────────────────
// Replaces the hardcoded PRODUCT_BASES array in product-bases.ts.
// Managed via the admin UI — can be populated from Printify catalog import
// or created manually.
model ProductBaseDef {
  id                  String   @id @default(cuid())
  shop                String

  // Identifiers
  slug                String   // e.g. "liberty-bags-oad113"
  name                String   // e.g. "Cotton Canvas Tote Bag"
  brand               String   // e.g. "Liberty Bags"
  model               String   // e.g. "OAD113"
  category            String   @default("accessory") // hat, shirt, hoodie, bag, accessory

  // Fulfillment provider
  fulfillmentProvider String   @default("printify") // "printful" | "printify"

  // Printful IDs (if applicable)
  printfulProductId   Int?     @default(0)

  // Printify IDs (if applicable)
  printifyBlueprintId Int?
  printifyProviderId  Int?

  // Techniques available (JSON array: [{"key":"dtg","displayName":"DTG Print","isDefault":true}])
  techniques          String   @default("[]")

  // Placements (JSON array of placement specs)
  placements          String   @default("[]")

  // Default print area position on mockup (% of image) — used as starting point
  defaultPrintAreaX      Float    @default(20)
  defaultPrintAreaY      Float    @default(20)
  defaultPrintAreaWidth  Float    @default(60)
  defaultPrintAreaHeight Float    @default(60)

  // Print file specs
  printFileWidth      Int      @default(3000)  // pixels
  printFileHeight     Int      @default(3600)  // pixels
  printFileDpi        Int      @default(300)

  // Default mockup image URL (fallback)
  defaultMockupUrl    String?

  // Description (from Printify catalog or manual)
  description         String?

  // Catalog images from Printify (JSON array of URLs)
  catalogImages       String   @default("[]")

  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  variants            ProductBaseVariant[]

  @@unique([shop, slug])
  @@index([shop])
}

// ─── Product Base Variant ───────────────────────────────────────────────────
// A color/size variant within a product base, with its own mockup image
// and optional print area override.
model ProductBaseVariant {
  id                  String   @id @default(cuid())
  productBaseId       String

  // Variant identifiers
  color               String   // e.g. "Natural", "Black"
  colorHex            String   @default("#ffffff")
  size                String?  // e.g. "S", "M", "L" (null for one-size products)

  // Fulfillment variant IDs
  printfulVariantId   Int?     @default(0)
  printifyVariantId   Int?

  // Mockup image for this variant
  mockupImageUrl      String?  // URL to the blank product photo

  // Print area position override for this variant (% of mockup image)
  // If null, uses the product base defaults
  printAreaX          Float?
  printAreaY          Float?
  printAreaWidth      Float?
  printAreaHeight     Float?

  isEnabled           Boolean  @default(true)
  sortOrder           Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  productBase         ProductBaseDef @relation(fields: [productBaseId], references: [id], onDelete: Cascade)

  @@unique([productBaseId, color, size])
  @@index([productBaseId])
}

// ─── Print File Storage ─────────────────────────────────────────────────────
// Stores generated print files as base64 in the database so they persist
// across Railway deployments and are always accessible via URL.
model PrintFile {
  id          String   @id @default(cuid())
  filename    String   @unique  // e.g. "pf-12345.png"
  mimeType    String   @default("image/png")
  data        String   // base64-encoded file data
  orderId     String?  // reference to PersonalizationOrder.id
  createdAt   DateTime @default(now())

  @@index([filename])
  @@index([orderId])
}
