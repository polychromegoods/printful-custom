// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model PersonalizationOrder {
  id                String   @id @default(cuid())
  shop              String
  shopifyOrderId    String
  shopifyOrderName  String
  shopifyVariantId  String
  customerEmail     String?
  customerName      String?

  // Personalization inputs
  monogramText      String
  monogramStyle     String   @default("script")
  threadColor       String   @default("#000000")

  // Processing status: pending | generating | uploading | submitting | completed | failed
  status            String   @default("pending")
  errorMessage      String?

  // Printful integration
  printFileUrl      String?
  printfulFileId    String?
  printfulOrderId   String?
  printfulStatus    String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([shop])
  @@index([shopifyOrderId])
  @@index([status])
}

// Product Base: links a Shopify product to personalization settings
// Includes print area position (as % of image) for overlay placement
model ProductBase {
  id                String   @id @default(cuid())
  shop              String
  shopifyProductId  String   // e.g. "gid://shopify/Product/123456"
  productTitle      String   // cached product title for display
  productHandle     String?  // cached product handle

  // Print area position as percentage of image dimensions (0-100)
  printAreaX        Float    @default(25)   // left edge %
  printAreaY        Float    @default(15)   // top edge %
  printAreaWidth    Float    @default(50)   // width %
  printAreaHeight   Float    @default(35)   // height %

  // Default font options
  enableScript      Boolean  @default(true)
  enableBlock       Boolean  @default(true)

  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  images            ProductBaseImage[]

  @@unique([shop, shopifyProductId])
  @@index([shop])
}

// Product Base Image: a blank mockup photo for a specific variant
// Each color variant gets its own blank mockup image
model ProductBaseImage {
  id                String   @id @default(cuid())
  productBaseId     String
  shopifyVariantId  String?  // null = default/fallback image
  variantTitle      String?  // e.g. "White", "Navy", "Black" (cached)
  imageUrl          String   // URL to the blank mockup image (Shopify Files CDN)
  sortOrder         Int      @default(0)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  productBase       ProductBase @relation(fields: [productBaseId], references: [id], onDelete: Cascade)

  @@unique([productBaseId, shopifyVariantId])
  @@index([productBaseId])
}
